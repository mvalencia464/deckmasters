---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { alaskaLandingCopy } from '../../data/marketingPagesCopy';

const site = (await import('../../data/site.json')).default;
const { serviceImages } = await import('../../data/serviceImages.ts');
const { serviceCategoryCardAssets } = await import('../../data/serviceCategoryCardImages.ts');
const primaryCategory = site.categories.find((c: { isPrimary: boolean }) => c.isPrimary);
const deckServices = primaryCategory
  ? primaryCategory.services.filter((s: { selected: boolean }) => s.selected).slice(0, 9)
  : [];
const neighborhoods = (site.neighborhoods as string[]) || [];
const mc = alaskaLandingCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
---

<Layout title={mc.title} description={mc.description}>
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Deck Builder</p>
      <h1 class="text-4xl md:text-5xl font-semibold text-neutral-800">{mc.h1}</h1>
      <p class="mt-6 text-lg text-neutral-600 max-w-3xl">
        {mc.lead}
      </p>
      <p class="mt-4 text-neutral-600 max-w-3xl">
        {mc.lead2}
      </p>
      <a
        href="/contact#quote"
        class="mt-8 inline-flex rounded-none bg-brand-orange hover:bg-orange-800 px-6 py-3 text-base font-medium text-white transition-colors duration-200 focus-ring"
      >
        {mc.ctaButton}
      </a>
    </div>
  </section>
  {deckServices.length > 0 && (
    <section class="py-16 lg:py-24 bg-surface-muted border-t border-neutral-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-semibold text-neutral-800">{mc.servicesH2}</h2>
        <p class="mt-2 text-neutral-600 max-w-2xl text-sm">{mc.servicesLead}</p>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {deckServices.map((s: { name: string }) => (
            <li>
              <ServiceCard
                title={s.name}
                href="/contact#quote"
                imageAsset={serviceCategoryCardAssets[s.name]}
                imageUrl={serviceImages[s.name]}
              />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
  {neighborhoods.length > 0 && (
    <section class="py-16 lg:py-24 bg-surface border-t border-neutral-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-semibold text-neutral-800">{mc.neighborhoodsH2}</h2>
        <p class="mt-3 text-neutral-600">{mc.neighborhoodsLead}</p>
        <ul class="mt-6 grid gap-2 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {neighborhoods.map((n) => (
            <li class="flex items-center gap-2 text-neutral-600">
              <span class="h-1.5 w-1.5 rounded-full bg-brand-orange shrink-0" aria-hidden="true" />
              {n}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
  <section class="py-20 bg-surface-muted border-t border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-neutral-600 max-w-xl mx-auto">{mc.ctaLead}</p>
      <a
        href="/contact#quote"
        class="mt-4 inline-flex rounded-none bg-brand-orange px-6 py-3 text-base font-medium text-white transition-colors duration-200 hover:bg-orange-800 focus-ring"
      >
        {mc.ctaButton}
      </a>
    </div>
  </section>
</Layout>
