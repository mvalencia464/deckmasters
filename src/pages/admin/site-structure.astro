---
import Layout from '../../layouts/Layout.astro';
import AdminInternalNav from '../../components/AdminInternalNav.astro';
import {
  topLevelSiteRoutes,
  getServiceTreeSections,
  getServicePageStats,
  kindStyles,
} from '../../data/siteStructureAdmin';

const site = (await import('../../data/site.json')).default;
const pathname = Astro.url.pathname;
const title = 'Site structure map (internal)';
const description = 'Internal-only visual map of URLs and /services hierarchy — not indexed.';

const treeSections = getServiceTreeSections();
const stats = getServicePageStats();
---

<Layout title={title} description={description} verbatimTitle noindex>
  <div class="min-h-[70vh] bg-surface text-neutral-800">
    <div
      class="border-b border-neutral-200 bg-surface-muted px-4 py-3.5 text-center text-sm text-neutral-700 shadow-sm"
      role="status"
    >
      <span class="inline-block border-l-4 border-brand-orange pl-3 text-left sm:text-center">
        <strong class="text-neutral-900">Internal only.</strong> This URL is <code class="rounded bg-neutral-200/80 px-1 py-0.5 text-xs text-neutral-800">noindex</code> and not in the sitemap. Do not link from public pages.
      </span>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">{site.businessName}</p>
      <h1 class="mt-2 font-display text-3xl sm:text-4xl font-bold uppercase tracking-tight text-neutral-900">
        Site structure
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-neutral-600 leading-relaxed">
        Visual map of public routes and the <strong class="text-neutral-800">/services</strong> tree (category → core hub → child pages). Service data lives in{' '}
        <code class="rounded border border-neutral-200 bg-white px-1.5 py-0.5 font-mono text-xs text-neutral-800"
          >src/data/siteArchitecture.ts</code
        > — see{' '}
        <code class="rounded border border-neutral-200 bg-white px-1.5 py-0.5 font-mono text-xs text-neutral-800"
          >docs/site-architecture-prompt-0.md</code
        > for the original spec.
      </p>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_280px] lg:items-start">
        <div class="space-y-14">
          <!-- Marketing & static pages -->
          <section>
            <h2 class="border-b border-neutral-200 pb-2 font-display text-xl font-bold uppercase tracking-tight text-neutral-900">
              Top-level pages
            </h2>
            <p class="mt-3 text-sm text-neutral-600">
              Fixed routes in <code class="rounded bg-neutral-100 px-1 font-mono text-xs">src/pages/</code>. Blog
              articles use dynamic <code class="rounded bg-neutral-100 px-1 font-mono text-xs">[slug].astro</code>.
            </p>
            <ul
              class="mt-6 grid gap-2 sm:grid-cols-2 xl:grid-cols-3"
              role="list"
            >
              {
                topLevelSiteRoutes.map((r) => (
                  <li class="flex min-h-11 items-center rounded-none border border-neutral-200 bg-white px-3 py-2 shadow-sm transition-shadow hover:shadow-md">
                    <a href={r.href} class="text-sm font-medium text-neutral-800 hover:text-brand-orange">
                      {r.label}
                    </a>
                    <span class="ml-auto truncate pl-2 font-mono text-[11px] text-neutral-400">{r.href}</span>
                  </li>
                ))
              }
            </ul>
          </section>

          <!-- Services tree -->
          <section>
            <h2 class="border-b border-neutral-200 pb-2 font-display text-xl font-bold uppercase tracking-tight text-neutral-900">
              Services architecture
            </h2>
            <p class="mt-3 text-sm text-neutral-600">
              Every row below maps to <span class="font-mono text-neutral-700">/services/[slug]</span>. Child pages
              inherit the category layout (Core30 / VOC copy).
            </p>

            <div class="mt-8 space-y-10">
              {
                treeSections.map(({ category, tree }) => (
                  <div class="rounded-none border border-neutral-200 bg-surface-elevated shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-neutral-200 bg-white px-4 py-3">
                      <div class="flex flex-wrap items-center gap-2">
                        <span
                          class:list={[
                            'inline-flex shrink-0 rounded-none border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider',
                            kindStyles.category.class,
                          ]}
                        >
                          {kindStyles.category.label}
                        </span>
                        <a
                          href={`/services/${category.slug}`}
                          class="font-display text-lg font-bold uppercase tracking-tight text-neutral-900 hover:text-brand-orange"
                        >
                          {category.title}
                        </a>
                      </div>
                      <a
                        href={`/services/${category.slug}`}
                        class="font-mono text-xs text-neutral-500 hover:text-brand-orange"
                      >
                        /services/{category.slug}
                      </a>
                    </div>

                    <div class="p-4">
                      {tree.mode === 'flat' ? (
                        <ul class="space-y-2" role="list">
                          {tree.leaves.map((leaf) => (
                            <li class="flex flex-wrap items-center gap-2 border-l-4 border-brand-orange/50 bg-white pl-3 py-2">
                              <span
                                class:list={[
                                  'inline-flex shrink-0 rounded-none border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider',
                                  kindStyles[leaf.kind].class,
                                ]}
                              >
                                {kindStyles[leaf.kind].label}
                              </span>
                              <a
                                href={`/services/${leaf.slug}`}
                                class="text-sm font-medium text-neutral-800 hover:text-brand-orange"
                              >
                                {leaf.title}
                              </a>
                              <span class="ml-auto hidden font-mono text-[11px] text-neutral-400 sm:inline">
                                /services/{leaf.slug}
                              </span>
                            </li>
                          ))}
                        </ul>
                      ) : (
                        <div class="space-y-6">
                          {tree.groups.map((g) => (
                            <div>
                              <div class="flex flex-wrap items-baseline gap-2 border-l-4 border-accent pl-3">
                                <span
                                  class:list={[
                                    'inline-flex shrink-0 rounded-none border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider',
                                    kindStyles.core.class,
                                  ]}
                                >
                                  {kindStyles.core.label}
                                </span>
                                <a
                                  href={`/services/${g.core.slug}`}
                                  class="font-semibold text-neutral-900 hover:text-brand-orange"
                                >
                                  {g.core.title}
                                </a>
                                <a
                                  href={`/services/${g.core.slug}`}
                                  class="ml-auto font-mono text-[11px] text-neutral-400 hover:text-brand-orange"
                                >
                                  /services/{g.core.slug}
                                </a>
                              </div>
                              {g.leaves.length > 0 ? (
                                <ul class="ml-0 mt-3 space-y-1.5 border-l-2 border-neutral-200 pl-6 sm:ml-4 sm:pl-6" role="list">
                                  {g.leaves.map((leaf) => (
                                    <li class="flex flex-wrap items-center gap-2 py-1">
                                      <span
                                        class:list={[
                                          'inline-flex shrink-0 rounded-none border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider',
                                          kindStyles.child.class,
                                        ]}
                                      >
                                        {kindStyles.child.label}
                                      </span>
                                      <a
                                        href={`/services/${leaf.slug}`}
                                        class="text-sm text-neutral-700 hover:text-brand-orange"
                                      >
                                        {leaf.title}
                                      </a>
                                      <span class="ml-auto hidden font-mono text-[10px] text-neutral-400 sm:inline">
                                        /services/{leaf.slug}
                                      </span>
                                    </li>
                                  ))}
                                </ul>
                              ) : (
                                <p class="ml-6 mt-2 text-xs text-neutral-500 sm:ml-10">No child pages under this hub.</p>
                              )}
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                ))
              }
            </div>
          </section>
        </div>

        <aside class="rounded-none border border-neutral-200 bg-white p-5 text-sm shadow-sm lg:sticky lg:top-24">
          <h3 class="border-b border-neutral-100 pb-2 font-display text-sm font-bold uppercase tracking-tight text-neutral-900">
            Counts
          </h3>
          <dl class="mt-4 space-y-2 text-neutral-600">
            <div class="flex justify-between gap-4">
              <dt>Service URLs (total)</dt>
              <dd class="font-semibold text-neutral-900">{stats.total}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt>Categories</dt>
              <dd class="font-semibold text-neutral-900">{stats.categories}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt>Core hubs</dt>
              <dd class="font-semibold text-neutral-900">{stats.cores}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt>Child pages</dt>
              <dd class="font-semibold text-neutral-900">{stats.children}</dd>
            </div>
          </dl>
          <p class="mt-6 border-t border-neutral-100 pt-4 text-xs leading-relaxed text-neutral-500">
            <strong class="text-neutral-700">Legend:</strong> Category = top hub; Core hub = mid-level (Prompt 5); Child =
            long-tail service page (Prompt 6).
          </p>
          <AdminInternalNav pathname={pathname} />
        </aside>
      </div>

      <p class="mt-14 text-center text-xs text-neutral-500">
        <a href="/" class="font-medium text-brand-orange transition-colors hover:text-orange-800">
          ← Back to site
        </a>
      </p>
    </div>
  </div>
</Layout>
