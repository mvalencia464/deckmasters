---
import Layout from '../../layouts/Layout.astro';
import AdminInternalNav from '../../components/AdminInternalNav.astro';
import { publishingWeeks, launchStrategy, deployCadenceNote } from '../../data/publishingPlan';

const site = (await import('../../data/site.json')).default;
const pathname = Astro.url.pathname;
const title = 'Publishing schedule & launch strategy (internal)';
const description = 'Internal-only calendar and SEO/GBP strategy — not indexed.';
---

<Layout title={title} description={description} verbatimTitle noindex>
  <div class="min-h-[70vh] bg-surface text-neutral-800">
    <div
      class="border-b border-neutral-200 bg-surface-muted px-4 py-3.5 text-center text-sm text-neutral-700 shadow-sm"
      role="status"
    >
      <span class="inline-block border-l-4 border-brand-orange pl-3 text-left sm:text-center">
        <strong class="text-neutral-900">Internal only.</strong> This URL is <code class="rounded bg-neutral-200/80 px-1 py-0.5 text-xs text-neutral-800">noindex</code> and not in the sitemap. Do not link from public pages. Not password-protected — share carefully.
      </span>
    </div>

    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">{site.businessName}</p>
      <h1 class="mt-2 font-display text-3xl sm:text-4xl font-bold uppercase tracking-tight text-neutral-900">
        Publishing &amp; launch plan
      </h1>
      <p class="mt-3 max-w-2xl text-sm text-neutral-600 leading-relaxed">
        Next several weeks at a glance, plus how the site works alongside Google Business Profile. Edit copy in{' '}
        <code class="rounded border border-neutral-200 bg-white px-1.5 py-0.5 font-mono text-xs text-neutral-800"
          >src/data/publishingPlan.ts</code
        >.
      </p>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_300px] lg:items-start">
        <div>
          <h2 class="border-b border-neutral-200 pb-2 font-display text-xl font-bold uppercase tracking-tight text-neutral-900">
            Next 8 weeks — what to ship
          </h2>
          <ol class="mt-6 space-y-5" role="list">
            {
              publishingWeeks.map((week) => (
                <li class="rounded-none border border-neutral-200 bg-surface-elevated p-5 shadow-sm transition-shadow hover:shadow-md">
                  <p class="text-xs font-bold uppercase tracking-wider text-brand-orange">{week.label}</p>
                  <p class="mt-1 font-semibold text-neutral-900">{week.theme}</p>
                  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-neutral-600 leading-relaxed" role="list">
                    {week.tasks.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                </li>
              ))
            }
          </ol>
        </div>

        <aside class="rounded-none border border-neutral-200 bg-white p-5 text-sm shadow-sm lg:sticky lg:top-24">
          <h3 class="border-b border-neutral-100 pb-2 font-display text-sm font-bold uppercase tracking-tight text-neutral-900">
            {deployCadenceNote.title}
          </h3>
          <ul class="mt-3 list-disc space-y-2 pl-4 text-neutral-600 leading-relaxed" role="list">
            {deployCadenceNote.lines.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
          <p class="mt-4 border-t border-neutral-100 pt-4 text-xs text-neutral-500">
            Public scheduling for customers:{' '}
            <a href="/schedule" class="font-medium text-accent-dark underline-offset-2 hover:underline">
              /schedule
            </a>{' '}
            (quotes).
          </p>
          <AdminInternalNav pathname={pathname} />
        </aside>
      </div>

      <section class="mt-16 border-t border-neutral-200 pt-12">
        <h2 class="border-b border-neutral-200 pb-2 font-display text-xl font-bold uppercase tracking-tight text-neutral-900">
          Launch &amp; ranking strategy
        </h2>
        <div class="mt-8 space-y-10">
          {
            launchStrategy.map((section) => (
              <div class="rounded-none border border-neutral-200 bg-white p-6 shadow-sm">
                <h3 class="font-display text-lg font-semibold uppercase tracking-wide text-brand-orange">{section.title}</h3>
                <p class="mt-2 text-sm text-neutral-600 leading-relaxed">{section.summary}</p>
                <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-neutral-600 leading-relaxed" role="list">
                  {section.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <p class="mt-14 text-center text-xs text-neutral-500">
        <a href="/" class="font-medium text-brand-orange transition-colors hover:text-orange-800">
          ← Back to site
        </a>
      </p>
    </div>
  </div>
</Layout>
