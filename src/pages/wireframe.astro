---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Homepage Wireframe" verbatimTitle noindex>
  <section class="border-b border-neutral-200 bg-surface py-14">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[1.15fr_0.85fr] lg:px-8">
      <div class="space-y-4">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Wireframe</p>
        <div class="h-4 w-44 rounded bg-neutral-300"></div>
        <div class="h-10 w-full max-w-xl rounded bg-neutral-300"></div>
        <div class="h-10 w-[90%] max-w-xl rounded bg-neutral-300"></div>
        <div class="h-4 w-full max-w-2xl rounded bg-neutral-200"></div>
        <div class="h-4 w-[96%] max-w-2xl rounded bg-neutral-200"></div>
        <div class="h-4 w-[76%] max-w-2xl rounded bg-neutral-200"></div>
        <div class="flex flex-wrap gap-3 pt-2">
          <div class="h-12 w-48 rounded border-2 border-neutral-400 bg-neutral-100"></div>
          <div class="h-12 w-40 rounded border-2 border-neutral-300 bg-white"></div>
        </div>
      </div>
      <div class="rounded border border-dashed border-neutral-400 bg-neutral-100 p-4">
        <div class="mb-3 h-4 w-40 rounded bg-neutral-300"></div>
        <div class="space-y-3 rounded border border-neutral-300 bg-white p-4">
          <div class="h-10 rounded bg-neutral-200"></div>
          <div class="h-10 rounded bg-neutral-200"></div>
          <div class="h-10 rounded bg-neutral-200"></div>
          <div class="h-10 rounded bg-neutral-300"></div>
          <p class="text-xs uppercase tracking-wider text-neutral-500">Lead Form / Instant Quote Widget</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-white py-6">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Trust Strip</p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="h-16 rounded border border-neutral-300 bg-neutral-100"></div>
        <div class="h-16 rounded border border-neutral-300 bg-neutral-100"></div>
        <div class="h-16 rounded border border-neutral-300 bg-neutral-100"></div>
        <div class="h-16 rounded border border-neutral-300 bg-neutral-100"></div>
      </div>
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-surface py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 space-y-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Services Grid</p>
        <div class="h-8 w-80 rounded bg-neutral-300"></div>
        <div class="h-4 w-full max-w-3xl rounded bg-neutral-200"></div>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {Array.from({ length: 6 }).map(() => (
          <article class="rounded border border-neutral-300 bg-white p-4">
            <div class="mb-4 h-36 rounded bg-neutral-200"></div>
            <div class="mb-3 h-5 w-3/4 rounded bg-neutral-300"></div>
            <div class="h-4 w-full rounded bg-neutral-200"></div>
            <div class="mt-2 h-4 w-4/5 rounded bg-neutral-200"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-white py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 space-y-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">How It Works</p>
        <div class="h-8 w-72 rounded bg-neutral-300"></div>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {Array.from({ length: 3 }).map(() => (
          <article class="rounded border border-neutral-300 bg-neutral-50 p-5">
            <div class="mb-4 h-10 w-10 rounded-full bg-neutral-300"></div>
            <div class="mb-3 h-5 w-2/3 rounded bg-neutral-300"></div>
            <div class="h-4 w-full rounded bg-neutral-200"></div>
            <div class="mt-2 h-4 w-5/6 rounded bg-neutral-200"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-surface py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 space-y-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Featured Project + Testimonial</p>
        <div class="h-8 w-96 rounded bg-neutral-300"></div>
      </div>
      <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded border border-neutral-300 bg-neutral-100 p-4">
          <div class="h-72 rounded bg-neutral-200"></div>
        </div>
        <div class="rounded border border-neutral-300 bg-white p-6">
          <div class="mb-4 h-6 w-40 rounded bg-neutral-300"></div>
          <div class="space-y-3">
            <div class="h-4 w-full rounded bg-neutral-200"></div>
            <div class="h-4 w-full rounded bg-neutral-200"></div>
            <div class="h-4 w-11/12 rounded bg-neutral-200"></div>
            <div class="h-4 w-4/5 rounded bg-neutral-200"></div>
          </div>
          <div class="mt-6 h-4 w-36 rounded bg-neutral-300"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-white py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 space-y-3">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">FAQ</p>
        <div class="h-8 w-52 rounded bg-neutral-300"></div>
      </div>
      <div class="space-y-3">
        {Array.from({ length: 5 }).map(() => (
          <div class="rounded border border-neutral-300 bg-neutral-50 p-4">
            <div class="h-5 w-3/4 rounded bg-neutral-300"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-surface py-16">
    <div class="mx-auto max-w-5xl rounded border border-neutral-300 bg-white px-6 py-10 sm:px-10">
      <div class="mx-auto max-w-3xl space-y-4 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Final CTA</p>
        <div class="mx-auto h-8 w-2/3 rounded bg-neutral-300"></div>
        <div class="mx-auto h-4 w-full rounded bg-neutral-200"></div>
        <div class="mx-auto h-4 w-5/6 rounded bg-neutral-200"></div>
        <div class="flex flex-wrap justify-center gap-3 pt-2">
          <div class="h-12 w-44 rounded border-2 border-neutral-400 bg-neutral-100"></div>
          <div class="h-12 w-44 rounded border-2 border-neutral-300 bg-white"></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
