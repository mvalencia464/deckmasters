---
import Layout from '../../layouts/Layout.astro';
import ProjectDiscoveryGrid from '../../components/ProjectDiscoveryGrid.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const allProjects = await getCollection('projects');
const otherProjects = allProjects.filter((p) => p.id !== project.id).slice(0, 3);

const title = data.title;
const description = data.description;

const videoInHero = !!(data.video && data.videoPlacement !== 'afterGallery');
const videoAfterGallery = !!(data.video && data.videoPlacement === 'afterGallery');
const walkthroughBlock =
  data.walkthroughIntro || (data.walkthroughQuotes && data.walkthroughQuotes.length > 0);
---

<Layout title={title} description={description}>
  <section class="py-12 sm:py-16 lg:py-20 bg-surface">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8">
        <a
          href="/#featured-project"
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500 hover:text-brand-orange transition-colors"
        >
          <span aria-hidden="true">←</span>
          Back to homepage
        </a>
      </nav>

      <header class="mt-6 sm:mt-8">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Featured Project</p>
        <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold text-neutral-900 tracking-tight">
          {data.h1}
        </h1>
        <p class="mt-3 text-sm sm:text-base text-neutral-600 max-w-2xl">
          {data.subhead}
        </p>
      </header>

      <div class="mt-8 sm:mt-10 rounded-none border border-neutral-200 bg-black shadow-sm overflow-hidden">
        {videoInHero ? (
          <div class="aspect-video w-full max-h-[70vh] min-h-[200px]">
            <video
              class="w-full h-full object-contain bg-black"
              width="1920"
              height="1080"
              controls
              preload="metadata"
              playsinline
            >
              <source src={data.video} type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        ) : (
          <div class="aspect-video w-full max-h-[70vh] min-h-[200px]">
            <Image
              src={data.featuredImage}
              alt={data.h1}
              width={1920}
              height={1080}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </div>

      {videoInHero && walkthroughBlock && (
        <div class="mt-8 sm:mt-10 rounded-none border border-neutral-200 bg-surface-elevated p-5 sm:p-6">
          <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-brand-orange mb-2">On-site walkthrough</p>
          <h2 class="font-display text-lg sm:text-xl font-semibold text-neutral-900 tracking-tight">
            Jordan walks the job with you
          </h2>
          {data.walkthroughIntro && (
            <p class="mt-3 text-sm leading-relaxed text-neutral-700">{data.walkthroughIntro}</p>
          )}
          {data.walkthroughQuotes && data.walkthroughQuotes.length > 0 && (
            <ul class="mt-5 space-y-3 text-sm text-neutral-700 border-t border-neutral-200 pt-5" role="list">
              {data.walkthroughQuotes.map((quote) => (
                <li class="relative pl-4 border-l-2 border-brand-orange/40">
                  <span class="italic leading-relaxed">{quote}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}

      <div class="mt-10 grid gap-8 md:grid-cols-[minmax(0,1.7fr)_minmax(0,1.1fr)] md:items-start">
        <div class="space-y-4 text-sm leading-relaxed text-neutral-700">
          <h2 class="font-semibold text-neutral-900 text-base">{data.sectionH2}</h2>
          <p>{data.p1}</p>
          <p>{data.p2}</p>
        </div>

        <aside class="space-y-5 rounded-none border border-neutral-200 bg-surface-elevated p-5 text-sm">
          <div>
            <h2 class="font-semibold text-neutral-900 text-base">Project snapshot</h2>
            <dl class="mt-3 space-y-2 text-neutral-700">
              <div class="flex justify-between gap-4">
                <dt class="text-neutral-500">Location</dt>
                <dd class="font-medium text-neutral-800 text-right">{data.location}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-neutral-500">Deck type</dt>
                <dd class="font-medium text-neutral-800 text-right">{data.deckType}</dd>
              </div>
              <div class="flex justify-between gap-4">
                <dt class="text-neutral-500">Key features</dt>
                <dd class="font-medium text-neutral-800 text-right">{data.keyFeatures}</dd>
              </div>
            </dl>
          </div>

          <div class="border-t border-neutral-200 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500 mb-2">
              Want a project like this?
            </p>
            <p class="text-sm text-neutral-700">
              When you are ready, request an estimate — we walk the site with you, talk options, and put a written plan in your hands.
            </p>
            <a
              href="/#quote"
              class="mt-4 inline-flex items-center justify-center px-4 py-2 bg-brand-orange hover:bg-orange-800 text-white text-xs font-bold uppercase tracking-[0.18em] rounded-none shadow-sm transition-colors focus-ring"
            >
              Get my free estimate →
            </a>
          </div>
        </aside>
      </div>

      {data.galleryImages && data.galleryImages.length > 0 && (
        <section class="mt-12 sm:mt-14 border-t border-neutral-200 pt-8 sm:pt-10">
          <div class="flex items-end justify-between gap-4 mb-5">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-brand-orange mb-1">
                Project Gallery
              </p>
              <h2 class="font-display text-xl sm:text-2xl font-semibold text-neutral-900 tracking-tight">
                360° view of this build
              </h2>
            </div>
            <p class="hidden sm:block text-[11px] text-neutral-500 max-w-xs text-right">
              Take a closer look at the details and craftsmanship that went into this project.
            </p>
          </div>
          <ul class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4" role="list">
            {data.galleryImages.map((img) => (
              <li>
                <Image
                  src={img}
                  alt={`Detail of ${data.h1}`}
                  width={640}
                  height={426}
                  class="w-full aspect-3/2 object-cover border border-neutral-200 bg-neutral-100 shadow-sm"
                />
              </li>
            ))}
          </ul>
        </section>
      )}

      {videoAfterGallery && (
        <div class="mt-12 sm:mt-14 rounded-none border border-neutral-200 bg-surface-elevated overflow-hidden shadow-sm">
          {walkthroughBlock ? (
            <div class="flex flex-col md:flex-row md:items-stretch">
              <div class="order-1 bg-black shrink-0 border-b md:border-b-0 md:border-r border-neutral-200 flex justify-center md:justify-start">
                <div class="relative aspect-[9/16] w-full max-w-[min(100%,22rem)] sm:max-w-[min(100%,26rem)] md:max-w-none md:w-72 lg:w-80">
                  <video
                    class="absolute inset-0 h-full w-full object-contain bg-black"
                    width="1080"
                    height="1920"
                    controls
                    preload="metadata"
                    playsinline
                  >
                    <source src={data.video} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                </div>
              </div>
              <div class="order-2 flex-1 min-w-0 p-5 sm:p-6 lg:p-8">
                <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-brand-orange mb-2">On-site walkthrough</p>
                <h2 class="font-display text-lg sm:text-xl font-semibold text-neutral-900 tracking-tight">
                  Jordan walks the job with you
                </h2>
                {data.walkthroughIntro && (
                  <p class="mt-3 text-sm leading-relaxed text-neutral-700">{data.walkthroughIntro}</p>
                )}
                {data.walkthroughQuotes && data.walkthroughQuotes.length > 0 && (
                  <ul class="mt-5 space-y-3 text-sm text-neutral-700 border-t border-neutral-200 pt-5" role="list">
                    {data.walkthroughQuotes.map((quote) => (
                      <li class="relative pl-4 border-l-2 border-brand-orange/40">
                        <span class="italic leading-relaxed">{quote}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ) : (
            <div class="bg-black flex justify-center p-2 sm:p-4">
              <div class="relative aspect-[9/16] w-full max-w-[min(100%,22rem)]">
                <video
                  class="absolute inset-0 h-full w-full object-contain bg-black"
                  width="1080"
                  height="1920"
                  controls
                  preload="metadata"
                  playsinline
                >
                  <source src={data.video} type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
              </div>
            </div>
          )}
        </div>
      )}

      <ProjectDiscoveryGrid projects={otherProjects} />
    </div>
  </section>
</Layout>
