---
import Layout from '../layouts/Layout.astro';
import { dockBuildingPageCopy } from '../data/marketingPagesCopy';

const site = (await import('../data/site.json')).default;
const mc = dockBuildingPageCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
---

<Layout title={mc.title} description={mc.description}>
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Services</p>
      <h1 class="text-4xl md:text-5xl font-semibold text-neutral-800">{mc.h1}</h1>
      <p class="mt-6 text-lg text-neutral-600">
        {mc.problemLead}
      </p>
      <p class="mt-4 text-neutral-600">
        {mc.body1}
      </p>
      <p class="mt-4 text-neutral-600">
        {mc.body2}
      </p>
      <a
        href="/contact#quote"
        class="mt-8 inline-flex rounded-none bg-brand-orange hover:bg-orange-800 px-6 py-3 text-base font-medium text-white transition-colors duration-200 focus-ring"
      >
        {mc.ctaPrimary}
      </a>
    </div>
  </section>
  <section class="py-20 bg-surface-muted border-t border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-neutral-600 max-w-xl mx-auto">{mc.ctaSectionLead}</p>
      <a
        href="/contact#quote"
        class="mt-4 inline-flex rounded-none bg-brand-orange px-6 py-3 text-base font-medium text-white transition-colors duration-200 hover:bg-orange-800 focus-ring"
      >
        {mc.ctaSecondary}
      </a>
    </div>
  </section>
</Layout>
