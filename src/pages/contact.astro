---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { contactPageCopy } from '../data/marketingPagesCopy';
import { homepageTrustStripItems } from '../data/copywritingLibrary';

const site = (await import('../data/site.json')).default;
const st = 'AK';
const mc = contactPageCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
const title = mc.title;
const description = mc.description;
const neighborhoods = (site.neighborhoods as string[]) || [];
const tel = site.primaryPhone.replace(/\D/g, '');
const siteOrigin = Astro.site?.origin ?? 'https://deckmastersak.com';
const businessId = `${siteOrigin}/#business`;
const mapsEmbedSrc = `https://maps.google.com/maps?q=${encodeURIComponent(site.address)}&output=embed`;
const mapsLinkUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address)}`;

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contact ${site.businessName}`,
  url: `${siteOrigin}/contact/`,
  description,
  mainEntity: { '@id': businessId },
};

const contactLocalBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': businessId,
  name: site.businessName,
  telephone: site.primaryPhone,
  email: site.primaryEmail || undefined,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '625 W 59th Ave Unit J',
    addressLocality: site.primaryCity,
    addressRegion: st,
    postalCode: '99518',
    addressCountry: 'US',
  },
};
---

<Layout title={title} description={description} verbatimTitle>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(contactPageSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(contactLocalBusiness)} />

  <section class="relative border-b border-neutral-200 bg-neutral-900 text-white overflow-hidden">
    <div
      class="absolute inset-0 opacity-35 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-700 via-neutral-900 to-neutral-900"
      aria-hidden="true"
    >
    </div>
    <div class="relative z-10 mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase tracking-tight">{mc.heroH1}</h1>
      <p class="mt-5 max-w-2xl text-lg text-neutral-200 leading-relaxed">
        {mc.heroLead}
      </p>
      <a
        href={`tel:${tel}`}
        class="mt-8 inline-block text-2xl sm:text-3xl font-bold text-white hover:text-brand-orange transition-colors tracking-tight"
      >
        {site.primaryPhone}
      </a>
      <ul class="mt-8 flex flex-wrap gap-3" role="list">
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
          Licensed &amp; insured
        </li>
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
          Free estimates
        </li>
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white max-w-md leading-snug">
          {homepageTrustStripItems[0].line}
        </li>
      </ul>
    </div>
  </section>

  <div class="bg-surface">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
      <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
        <div class="lg:col-span-2 space-y-10">
          <div>
            <h2 class="font-display text-lg font-bold uppercase tracking-tight text-neutral-800">{mc.callH2}</h2>
            <a
              href={`tel:${tel}`}
              class="mt-2 block text-2xl font-bold text-neutral-900 hover:text-brand-orange transition-colors"
            >
              {site.primaryPhone}
            </a>
            <p class="mt-2 text-sm text-neutral-600">
              {mc.callBlurb}
            </p>
          </div>

          <div>
            <h2 class="font-display text-lg font-bold uppercase tracking-tight text-neutral-800">{mc.emailH2}</h2>
            {
              site.primaryEmail ? (
                <>
                  <a
                    href={`mailto:${site.primaryEmail}`}
                    class="mt-2 block text-lg font-medium text-brand-orange hover:underline"
                  >
                    {site.primaryEmail}
                  </a>
                  <p class="mt-2 text-sm text-neutral-600">{mc.emailBlurb}</p>
                </>
              ) : (
                <p class="mt-2 text-sm text-neutral-600">
                  {mc.emailFallback}
                </p>
              )
            }
          </div>

          <div>
            <h2 class="font-display text-lg font-bold uppercase tracking-tight text-neutral-800">{mc.locationH2}</h2>
            <p class="mt-2 text-neutral-600 leading-relaxed">{site.address}</p>
            <a href={mapsLinkUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-block text-sm font-medium text-brand-orange hover:underline">
              Open in Google Maps →
            </a>
          </div>

          <div>
            <h2 class="font-display text-lg font-bold uppercase tracking-tight text-neutral-800">{mc.hoursH2}</h2>
            <p class="mt-2 text-neutral-600">{site.operatingHours || mc.hoursFallback}</p>
          </div>
        </div>

        <div class="lg:col-span-3" id="quote">
          <p class="text-sm text-neutral-600 mb-4">
            {mc.formHintBefore}
            <a href={`tel:${tel}`} class="font-semibold text-brand-orange hover:underline">{site.primaryPhone}</a>
            {mc.formHintAfter}
          </p>
          <div class="bg-neutral-900 border-[3px] border-neutral-700 p-6 sm:p-8 rounded-none max-w-xl shadow-xl shadow-black/40">
            <QuoteForm includeServiceSelect />
          </div>
        </div>
      </div>

      <section class="mt-16 pt-16 border-t border-neutral-200">
        <h2 class="font-display text-xl md:text-2xl font-bold uppercase tracking-tight text-neutral-800">{mc.areasH2}</h2>
        <p class="mt-3 text-neutral-600 leading-relaxed max-w-2xl">
          {mc.areasLead}
        </p>
        {
          neighborhoods.length > 0 && (
            <ul class="mt-6 grid gap-2 sm:grid-cols-2 lg:grid-cols-3 text-sm text-neutral-600" role="list">
              {neighborhoods.map((n: string) => (
                <li class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-brand-orange shrink-0" aria-hidden="true" />
                  {n}
                </li>
              ))}
            </ul>
          )
        }
      </section>

      <section class="mt-16">
        <h2 class="font-display text-xl md:text-2xl font-bold uppercase tracking-tight text-neutral-800">{mc.findUsH2}</h2>
        <p class="mt-2 text-sm text-neutral-600">{mc.findUsLead}</p>
        <div class="mt-6 aspect-[16/10] w-full max-w-3xl border border-neutral-200 bg-neutral-100 overflow-hidden">
          <iframe
            title="Map — Deck Masters AK location"
            src={mapsEmbedSrc}
            width="600"
            height="450"
            class="w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
        <a href={mapsLinkUrl} target="_blank" rel="noopener noreferrer" class="mt-4 inline-block text-sm font-medium text-brand-orange hover:underline">
          View larger map →
        </a>
      </section>

      <section class="mt-16 rounded-none border border-neutral-200 bg-surface-muted p-8 text-center max-w-3xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-wider text-neutral-500">{mc.trustEyebrow}</p>
        <p class="mt-3 text-neutral-800 font-medium">
          {mc.trustLine}
        </p>
      </section>
    </div>
  </div>
</Layout>
