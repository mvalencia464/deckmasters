---
import Layout from '../layouts/Layout.astro';
import CustomerSuccessManager from '../components/CustomerSuccessManager.astro';

const site = (await import('../data/site.json')).default;
const title = `Customer Success Manager | ${site.businessName}`;
const description =
  'Preview the DeckMasters customer success manager assignment card without submitting the quote form.';
---

<Layout title={title} description={description}>
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-semibold text-neutral-800 mb-4">
        Customer Success Manager Preview
      </h1>
      <p class="max-w-2xl text-neutral-600 mb-10">
        This page shows the customer success manager assignment card by itself so you can refine copy, layout, and
        styling without submitting the quote form each time.
      </p>
      <CustomerSuccessManager />
    </div>
  </section>
</Layout>

