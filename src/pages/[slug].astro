---
/**
 * Root-level blog post URLs to preserve old WordPress slugs for SEO.
 * Only blog collection entries are generated here; static pages (about, contact, etc.) are unchanged.
 * Duplicate URLs under `/blog/[slug]` are defined in `src/pages/blog/[slug].astro`.
 */
import Layout from '../layouts/Layout.astro';
import BlogPostArticle from '../components/BlogPostArticle.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const site = (await import('../data/site.json')).default;
const title = `${post.data.title} | Blog — ${site.businessName}`;
const description = post.data.description;
---

<Layout title={title} description={description}>
  <BlogPostArticle post={post} />
</Layout>
