---
import Layout from '../layouts/Layout.astro';
import { customerMapPageCopy } from '../data/marketingPagesCopy';
import { homepageTrustStripItems } from '../data/copywritingLibrary';

const site = (await import('../data/site.json')).default;
const mc = customerMapPageCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
const title = mc.title;
const description = mc.description;
const tel = site.primaryPhone.replace(/\D/g, '');

/** Felt embed — lazy-loaded iframe; only this route includes it (see mapHelp copy). */
const feltMapEmbedSrc =
  'https://felt.com/embed/map/Deck-Masters-Customers-bvOCjLwFQpuAMWhS9BbVDtA?loc=61.1946%2C-149.7497%2C10.51z&legend=1&cooperativeGestures=1&link=1&geolocation=0&zoomControls=1&scaleBar=1';

const siteOrigin = Astro.site?.origin ?? 'https://deckmastersak.com';
const pageUrl = `${siteOrigin}/customer-map/`;
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: mc.h1,
  url: pageUrl,
  description,
  isPartOf: { '@type': 'WebSite', name: site.businessName, url: siteOrigin },
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(webPageSchema)} />

  <section class="relative border-b border-neutral-200 bg-neutral-900 text-white overflow-hidden">
    <div
      class="absolute inset-0 opacity-35 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-700 via-neutral-900 to-neutral-900"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-0 z-[1] opacity-90"
      style="background: radial-gradient(ellipse 80% 55% at 15% 10%, rgba(193,78,10,0.18) 0%, transparent 52%), radial-gradient(ellipse 65% 45% at 85% 92%, rgba(13,148,136,0.12) 0%, transparent 48%)"
      aria-hidden="true"
    >
    </div>
    <div class="relative z-10 mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">Customers</p>
      <h1 class="mt-2 font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase tracking-tight max-w-4xl">
        {mc.h1}
      </h1>
      <p class="mt-5 max-w-2xl text-base sm:text-lg text-neutral-200 leading-relaxed">
        {mc.lead}
      </p>
      <a
        href={`tel:${tel}`}
        class="mt-8 inline-block text-2xl sm:text-3xl font-bold text-white hover:text-brand-orange transition-colors tracking-tight"
      >
        {site.primaryPhone}
      </a>
      <ul class="mt-8 flex flex-wrap gap-3" role="list">
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
          Licensed &amp; insured
        </li>
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
          Free estimates
        </li>
        <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white max-w-md leading-snug">
          {homepageTrustStripItems[0].line}
        </li>
      </ul>
    </div>
  </section>

  <section class="border-t border-neutral-200 bg-surface py-14 sm:py-16 lg:py-20" aria-labelledby="customer-map-heading">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">{mc.sectionEyebrow}</p>
      <h2 id="customer-map-heading" class="mt-2 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
        {mc.sectionH2}
      </h2>
      <p class="mt-3 max-w-2xl text-sm sm:text-base text-neutral-600 leading-relaxed">
        {mc.mapHelp}
      </p>

      <div
        class="mt-8 overflow-hidden border border-neutral-200 border-l-4 border-l-brand-orange bg-surface-elevated shadow-md"
      >
        <iframe
          width="100%"
          height="488"
          title="Deck Masters customer map"
          src={feltMapEmbedSrc}
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
          class="block w-full min-h-[488px] border-0 bg-neutral-100"
        ></iframe>
      </div>

      <p class="mt-4 text-xs text-neutral-500 max-w-3xl leading-relaxed">
        {mc.attribution}
      </p>

      <p class="mt-10 text-center text-neutral-600 text-sm">
        Ready to add your property to the list?
        <a href="/contact#quote" class="font-semibold text-brand-orange underline-offset-2 hover:underline">Request a free estimate</a>
      </p>
    </div>
  </section>
</Layout>
