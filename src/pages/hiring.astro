---
import Layout from '../layouts/Layout.astro';
import { hiringPageCopy } from '../data/marketingPagesCopy';

const site = (await import('../data/site.json')).default;
const mc = hiringPageCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
---

<Layout title={mc.title} description={mc.description}>
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-semibold text-neutral-800">{mc.h1}</h1>
      <p class="mt-4 text-lg text-neutral-600">
        {mc.lead}
      </p>
      <div class="mt-10 prose prose-neutral max-w-none text-neutral-600">
        <p>
          {mc.body}
        </p>
        <h2 class="text-xl font-semibold text-neutral-800 mt-10">{mc.applyH2}</h2>
        <p>
          {mc.applyBody}
        </p>
      </div>
      <div class="mt-12 p-6 bg-neutral-100 border border-neutral-200 rounded-none">
        <h2 class="text-lg font-semibold text-neutral-800">{mc.boxH2}</h2>
        <p class="mt-2 text-neutral-600">
          Call <a href={`tel:${site.primaryPhone.replace(/\D/g, '')}`} class="font-medium text-brand-orange hover:underline">{site.primaryPhone}</a>
          {' '}or use our <a href="/contact#quote" class="font-medium text-brand-orange hover:underline">contact form</a> and mention you are interested in joining the team.
        </p>
      </div>
    </div>
  </section>
</Layout>
