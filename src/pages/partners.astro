---
import Layout from '../layouts/Layout.astro';
import PartnerForm from '../components/PartnerForm.astro';
import { partnersPageCopy } from '../data/marketingPagesCopy';

const site = (await import('../data/site.json')).default;
const mc = partnersPageCopy({
  businessName: site.businessName,
  primaryCity: site.primaryCity,
  primaryPhone: site.primaryPhone,
  ownerName: site.ownerName,
});
---

<Layout title={mc.title} description={mc.description}>
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] items-start">
        <div class="space-y-6 text-neutral-700 text-base leading-relaxed">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">
              {mc.eyebrow}
            </p>
            <h1 class="text-4xl font-semibold text-neutral-800 flex flex-col gap-1">
              <span>{mc.h1Line1}</span>
              <span>{mc.h1Line2}</span>
            </h1>
            <p class="mt-4 text-lg text-neutral-600">
              {mc.intro}
            </p>
          </div>
          <h2 class="text-xl font-semibold text-neutral-800">
            {mc.benefitsH2}
          </h2>
          <ul class="space-y-3 text-neutral-700">
            <li class="flex gap-3">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-orange flex-shrink-0"></span>
              <div>
                <p class="font-semibold text-neutral-800">{mc.benefit1Title}</p>
                <p class="text-sm text-neutral-600">
                  {mc.benefit1Body}
                </p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-orange flex-shrink-0"></span>
              <div>
                <p class="font-semibold text-neutral-800">{mc.benefit2Title}</p>
                <p class="text-sm text-neutral-600">
                  {mc.benefit2Body}
                </p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-orange flex-shrink-0"></span>
              <div>
                <p class="font-semibold text-neutral-800">{mc.benefit3Title}</p>
                <p class="text-sm text-neutral-600">
                  {mc.benefit3Body}
                </p>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-orange flex-shrink-0"></span>
              <div>
                <p class="font-semibold text-neutral-800">{mc.benefit4Title}</p>
                <p class="text-sm text-neutral-600">
                  {mc.benefit4Body}
                </p>
              </div>
            </li>
          </ul>

          <h2 class="text-xl font-semibold text-neutral-800 mt-8">
            {mc.fitH2}
          </h2>
          <p class="text-sm text-neutral-600">
            {mc.fitBody}
          </p>
        </div>

        <div class="bg-neutral-900 border-[3px] border-neutral-700 p-6 sm:p-8 rounded-none shadow-xl shadow-black/40">
          <PartnerForm />
        </div>
      </div>
    </div>
  </section>
</Layout>
