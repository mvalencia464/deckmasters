---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import HomeWhyChoose from '../components/HomeWhyChoose.astro';
import HomeFaq from '../components/HomeFaq.astro';
import HomeMapSection from '../components/HomeMapSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Gallery from '../components/Gallery.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import { Image } from 'astro:assets';
import ownerImg from '../assets/jordanwebb.png';
import { homeMeta, getWhyChooseUs, homeFaqs, getFinalCta, homeServicesSectionLead } from '../data/homepageCopy';
import { fascinationBundles } from '../data/copywritingLibrary';
import FascinationBulletsBand from '../components/FascinationBulletsBand.astro';
import HomeVocSections from '../components/HomeVocSections.astro';

const site = (await import('../data/site.json')).default;
const { serviceImages } = await import('../data/serviceImages.ts');
const googleData = (await import('../data/google-reviews.json')).default;
const googleRaw = googleData.rawReviews ?? [];
const josephLeman = googleRaw.find((r: { author: string }) => r.author === 'Joseph Leman') ?? null;

const statsGoogle = googleRaw.filter((r: { source?: string; rating?: number }) =>
  String(r.source ?? '').toLowerCase().includes('google') && Number(r.rating) > 0
);
const googleReviewCount = statsGoogle.length;
const googleAverageRating = statsGoogle.length
  ? (statsGoogle.reduce((a: number, r: { rating?: number }) => a + Number(r.rating), 0) / googleReviewCount).toFixed(1)
  : '5.0';

const whyChooseItems = getWhyChooseUs(googleReviewCount, googleAverageRating);
const finalCta = getFinalCta(site.primaryPhone);

const primaryCategory = site.categories.find((c: { isPrimary: boolean }) => c.isPrimary);
const featuredServices = primaryCategory
  ? primaryCategory.services
      .filter((s: { selected: boolean }) => s.selected)
      .slice(0, 6)
      .map((s: { name: string }) => s.name)
  : [];

const siteOrigin = Astro.site?.origin ?? 'https://deckmastersak.com';
const businessId = `${siteOrigin}/#business`;

const addrMatch = site.address.match(/^(.+),\s*([^,]+),\s*([A-Z]{2})\s*(\d{5})/);
const streetAddress = addrMatch?.[1]?.trim() ?? site.address;
const addressLocality = addrMatch?.[2]?.trim() ?? 'Anchorage';
const addressRegion = addrMatch?.[3] ?? 'AK';
const postalCode = addrMatch?.[4] ?? '99518';

const sameAs = [site.socials.instagram, site.socials.facebook, site.socials.linkedin].filter(Boolean);

const primaryCategoryName = primaryCategory?.name ?? 'Deck Builder';

const businessNode: Record<string, unknown> = {
  '@type': 'HomeAndConstructionBusiness',
  '@id': businessId,
  name: site.businessName,
  description: homeMeta.description,
  url: `${siteOrigin}/`,
  telephone: site.primaryPhone,
  image: `${siteOrigin}/projects/009-masterpiece-main.avif`,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress,
    addressLocality,
    addressRegion,
    postalCode,
    addressCountry: 'US',
  },
  areaServed: site.neighborhoods.map((n: string) => `${n}, Anchorage, AK`),
  sameAs,
};
if (site.primaryEmail) businessNode.email = site.primaryEmail;

const graph: Record<string, unknown>[] = [
  businessNode,
  {
    '@type': 'Service',
    name: primaryCategoryName,
    serviceType: primaryCategoryName,
    provider: { '@id': businessId },
    areaServed: {
      '@type': 'City',
      name: site.primaryCity,
      containedInPlace: { '@type': 'State', name: 'Alaska' },
    },
    description: `Deck builder and exterior contractor in ${site.primaryCity}, Alaska — custom decks, repairs, railings, and related work.`,
  },
  {
    '@type': 'FAQPage',
    mainEntity: homeFaqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: f.answer,
      },
    })),
  },
];

const structuredDataJson = { '@context': 'https://schema.org', '@graph': graph };
---

<Layout title={homeMeta.title} description={homeMeta.description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredDataJson)} />
  <Hero />
  <TrustBar />
  <FascinationBulletsBand
    bundle={fascinationBundles.deckBuilding}
    heading="What Anchorage homeowners say about the finished job"
    eyebrow="Straight from reviews"
    layout="wide"
  />
  <HomeVocSections />
  <HomeWhyChoose items={whyChooseItems} />
  <section class="py-12 sm:py-16 lg:py-24 bg-surface border-t border-neutral-200" aria-label="Services">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Services</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">What We Build.</h2>
        <p class="mt-3 text-neutral-600 max-w-2xl leading-relaxed">
          {homeServicesSectionLead} Beyond decks: repairs and exterior work — built for {site.primaryCity}&apos;s climate.
        </p>
      </div>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {featuredServices.map((name) => (
          <li>
            <ServiceCard title={name} href="/services" imageUrl={serviceImages[name]} />
          </li>
        ))}
      </ul>
      <p class="mt-10">
        <a href="/services" class="text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider">
          View all services →
        </a>
      </p>
    </div>
  </section>
  <Gallery />
  <FeaturedProject josephReview={josephLeman} />
  <ReviewsSection />
  <section class="py-20 lg:py-28 bg-surface border-t border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="relative">
          <Image
            src={ownerImg}
            alt="Jordan Webb, owner of Deck Masters, smiling in a white shirt and hat."
            width={900}
            height={675}
            loading="lazy"
            decoding="async"
            class="aspect-4/3 w-full object-cover border border-neutral-200 bg-neutral-100 shadow-sm"
          />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">
            Our Story
          </p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-neutral-800 tracking-tight">
            Your Backyard, Built for a Lifetime
          </h2>
          <div class="mt-6 space-y-4 text-neutral-600 leading-relaxed">
            <p>
              Hi, I'm Jordan Webb. I started Deck Masters because I knew there was a better way to build in Alaska. Deck building isn't just a business to me—it's about giving you a flawless outdoor space where you'll make memories for the next 30 to 50 years.
            </p>
            <p>
              I started this company to fix the headaches people usually experience with construction. In an industry where contractors often struggle to manage schedules, delay material deliveries, and leave job sites a mess, we stand for something different. We aren't a weekend "handyman" service; we have spent years mastering a foolproof system that takes the stress completely off your shoulders.
            </p>
            <p>
              We believe in unmatched quality, super high integrity, and total transparency. When you hire us, you are getting specialty contractors who engineer decks specifically for the Alaskan elements. We treat your home as a sanctuary—our goal is for you to feel so safe and comfortable with our crew that you don't even need to lock your deadbolt while we work. We aren't perfect, but we promise this: when we make a mistake, we own it, and we make it right.
            </p>
            <p>
              With nearly 1,000 custom decks completed, we're proud to be Alaska's #1 rated, most trusted choice for outdoor living.
            </p>
          </div>
          <a
            href="/about"
            class="mt-8 inline-flex items-center text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider transition-colors duration-200"
          >
            Learn more →
          </a>
        </div>
      </div>
    </div>
  </section>
  <HomeFaq faqs={homeFaqs} />
  <HomeMapSection
    businessName={site.businessName}
    address={site.address}
    phone={site.primaryPhone}
    placeId={site.googlePlaceId}
    finalCta={finalCta}
  />
</Layout>
