---
import type { ServicePageEntry } from '../data/siteArchitecture';
import type { ServiceCategoryId } from '../data/siteArchitecture';
import {
  getAllChildLeavesInCategory,
  getServiceGroupsForCategory,
  getServicePage,
  getChildren,
} from '../data/siteArchitecture';
import type { CategoryPageBundle } from '../data/categoryPageCopy';
import { categoryPageCopy } from '../data/categoryPageCopy';
import { categoryVocQuotes } from '../data/servicePageVoc';
import ServiceCard from './ServiceCard.astro';
import VocQuoteCard from './VocQuoteCard.astro';
import ServiceImageTextBand from './ServiceImageTextBand.astro';
import { getCategoryVisualBand } from '../data/servicePageVisualBands';
import FascinationBulletsBand from './FascinationBulletsBand.astro';
import { getFascinationForPage } from '../data/servicePageFascination';
import ServicePageTrustBand from './ServicePageTrustBand.astro';
import ProjectPicture from './ProjectPicture.astro';

interface Props {
  page: ServicePageEntry;
  site: {
    businessName: string;
    primaryCity: string;
    primaryPhone: string;
  };
  serviceImages: Record<string, string>;
}

const { page, site, serviceImages } = Astro.props;
const cat = page.slug as ServiceCategoryId;
const copy: CategoryPageBundle = categoryPageCopy[cat];

function ancestorChain(slug: string): ServicePageEntry[] {
  const rev: ServicePageEntry[] = [];
  let cur: ServicePageEntry | undefined = getServicePage(slug);
  while (cur) {
    rev.push(cur);
    cur = cur.parentSlug ? getServicePage(cur.parentSlug) : undefined;
  }
  return rev.reverse();
}

const chain = ancestorChain(page.slug);
const groups = getServiceGroupsForCategory(cat);
const allChildLeaves = getAllChildLeavesInCategory(cat);
const kids = getChildren(page.slug);
const tel = site.primaryPhone.replace(/\D/g, '');
const city = site.primaryCity;
const st = 'AK';
const h1 = `${page.title} in ${city}, ${st} — ${copy.h1Benefit}`;
const vocList = categoryVocQuotes[cat];
const vocRest = vocList?.slice(1) ?? [];
const heroQuote = vocList?.[0] ?? null;
const visualBand = getCategoryVisualBand(cat, copy, vocList?.[0] ?? null);
const fascination = getFascinationForPage(page);
---

<section class="relative min-h-[min(52vh,480px)] flex flex-col justify-end overflow-hidden border-b border-neutral-200">
  <ProjectPicture
    src={copy.heroImage}
    alt=""
    pictureClass="absolute inset-0 block h-full w-full"
    imgClass="h-full w-full object-cover"
    width={1920}
    height={1080}
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-linear-to-t from-neutral-900/95 via-neutral-900/70 to-neutral-900/45" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto w-full max-w-6xl px-4 pb-12 pt-8 sm:px-6 sm:pb-14 sm:pt-10 lg:px-8">
    <nav class="text-sm text-neutral-300 mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap gap-x-2 gap-y-1 items-center" role="list">
        <li><a href="/" class="hover:text-brand-orange">Home</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/services" class="hover:text-brand-orange">Services</a></li>
        {
          chain.map((c, i) => (
            <>
              <li aria-hidden="true">/</li>
              <li>
                {i === chain.length - 1 ? (
                  <span class="text-white font-medium">{c.title}</span>
                ) : (
                  <a href={`/services/${c.slug}`} class="hover:text-brand-orange">
                    {c.title}
                  </a>
                )}
              </li>
            </>
          ))
        }
      </ol>
    </nav>
    <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-bold uppercase tracking-tight text-white max-w-4xl drop-shadow-sm">
      {h1}
    </h1>
    {
      heroQuote && (
        <blockquote class="mt-5 max-w-3xl border-l-4 border-brand-orange pl-4 text-sm sm:text-base text-neutral-200 leading-relaxed">
          "{heroQuote.excerpt}" — {heroQuote.author}
        </blockquote>
      )
    }
    <ul class="mt-6 flex flex-wrap gap-3" role="list">
      {
        copy.trustPills.map((t) => (
          <li class="rounded-none border border-white/25 bg-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-white">
            {t}
          </li>
        ))
      }
    </ul>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href={`tel:${tel}`}
        class="inline-flex rounded-none bg-brand-orange px-6 py-3 text-base font-bold uppercase tracking-wider text-white transition-colors hover:bg-orange-800 focus-ring"
      >
        Call {site.primaryPhone}
      </a>
      <a
        href="/contact#quote"
        class="inline-flex rounded-none border-2 border-white/80 px-6 py-3 text-base font-bold uppercase tracking-wider text-white hover:bg-white hover:text-neutral-900 transition-colors focus-ring"
      >
        {copy.heroSecondaryCta}
      </a>
    </div>
  </div>
</section>

<article class="bg-surface">
  <div class="mx-auto max-w-3xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <div class="prose prose-neutral max-w-none prose-p:text-neutral-600 prose-p:leading-relaxed prose-p:mt-4 first:prose-p:mt-0">
      {
        copy.opening.length > 1 ? (
          <p>{copy.opening[0]}</p>
        ) : (
          copy.opening.map((p) => <p>{p}</p>)
        )
      }
      {
        page.slug === 'deck-building' && (
          <p class="text-neutral-600 leading-relaxed mt-4">
            If you only need boards replaced without a full rebuild, see our{' '}
            <a href="/services/deck-board-replacement" class="text-brand-orange font-medium hover:underline">
              deck board replacement
            </a>{' '}
            service — scoped under repair so you do not pay for a new build when boards alone need work.
          </p>
        )
      }
    </div>
  </div>
</article>

<ServiceImageTextBand band={visualBand} />

{
  fascination && (
    <FascinationBulletsBand
      bundle={fascination}
      heading={`Why ${page.title.toLowerCase()} homeowners call us`}
      layout="wide"
    />
  )
}

<article class="bg-surface">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pb-14 lg:pb-16 lg:pt-0">
    <h2 class="mt-0 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800 lg:mt-2">
      {copy.problemsTitle}
    </h2>
    <div class="mt-6 space-y-4 text-neutral-600 leading-relaxed">
      {copy.problems.map((p) => <p>{p}</p>)}
    </div>

    <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
      {copy.agitationTitle}
    </h2>
    <div class="mt-6 space-y-4 text-neutral-600 leading-relaxed">
      {copy.agitation.map((p) => <p>{p}</p>)}
    </div>

    {
      vocRest.length > 0 && (
        <div class="mt-10">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-3">Homeowners said it</p>
          <ul class="grid gap-6 sm:grid-cols-2 list-none p-0 m-0" role="list">
            {vocRest.map((snippet) => (
              <li>
                <VocQuoteCard snippet={snippet} compact />
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
      Our {page.title} services
    </h2>
    <p class="mt-4 text-neutral-600 leading-relaxed">{copy.servicesIntro}</p>

    <div class="mt-8 space-y-10">
      {
        groups.map((group) => (
          <div>
            {group.core && (
              <h3 class="text-lg font-bold text-neutral-800">
                <a href={`/services/${group.core.slug}`} class="text-brand-orange hover:underline">
                  {group.core.title}
                </a>
              </h3>
            )}
            {group.core && copy.coreLead?.[group.core.slug] && (
              <p class="mt-2 text-neutral-600 leading-relaxed">{copy.coreLead[group.core.slug]}</p>
            )}
            <p class="mt-3 text-neutral-600 leading-relaxed">
              {group.leaves.map((leaf, i) => (
                <>
                  {i === 0 ? '' : i === group.leaves.length - 1 ? ' and ' : ', '}
                  <a href={`/services/${leaf.slug}`} class="font-medium text-brand-orange hover:underline">
                    {leaf.title}
                  </a>
                </>
              ))}
              .
            </p>
          </div>
        ))
      }
    </div>

    {
      allChildLeaves.length > 0 && (
        <div class="mt-14">
          <h2 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
            All {page.title} service pages
          </h2>
          <p class="mt-4 text-sm text-neutral-600 leading-relaxed">
            Same-scope siblings — jump to any line item for full detail. Each links to a dedicated URL under this category.
          </p>
          <ul
            class="mt-6 grid gap-x-6 gap-y-2 sm:grid-cols-2 text-sm list-none p-0 m-0"
            role="list"
          >
            {allChildLeaves.map((leaf) => (
              <li>
                <a href={`/services/${leaf.slug}`} class="font-medium text-brand-orange hover:underline">
                  {leaf.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
      {copy.cityTitle}
    </h2>
    <div class="mt-6 space-y-4 text-neutral-600 leading-relaxed">
      {(copy.opening.length > 1 ? copy.city.slice(1) : copy.city).map((p) => <p>{p}</p>)}
    </div>

    <h2 class="mt-14 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
      {copy.whyTitle}
    </h2>
    <div class="mt-6 space-y-4 text-neutral-600 leading-relaxed">
      {copy.why.map((p) => <p>{p}</p>)}
    </div>

    <p class="mt-10 text-neutral-600 leading-relaxed">
      Looking for the full company story? Start at our{' '}
      <a href="/" class="font-medium text-brand-orange hover:underline">Anchorage deck builder home page</a> — then come
      back here for the service line that fits your job.
    </p>

    <ServicePageTrustBand />

    <div class="mt-10 rounded-none border border-neutral-200 bg-surface-muted p-6">
      <p class="text-neutral-800 font-semibold">Ready to talk?</p>
      <p class="mt-2 text-neutral-600 text-sm leading-relaxed">{copy.finalCta}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href={`tel:${tel}`} class="inline-flex rounded-none bg-brand-orange px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-white hover:bg-orange-800">
          Call now
        </a>
        <a
          href="/contact#quote"
          class="inline-flex rounded-none border-2 border-neutral-300 px-5 py-2.5 text-sm font-bold uppercase tracking-wider text-neutral-800 hover:border-brand-orange hover:text-brand-orange"
        >
          Request a quote
        </a>
      </div>
    </div>
  </div>
</article>

{
  kids.length > 0 && (
    <section class="border-t border-neutral-200 bg-surface-muted py-14 lg:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-semibold text-neutral-800">Explore services</h2>
        <p class="mt-2 text-sm text-neutral-600">Jump to a hub or a specific service.</p>
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
          {kids.map((k) => (
            <li>
              <ServiceCard title={k.title} href={`/services/${k.slug}`} imageUrl={serviceImages[k.title]} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
