---
interface Props {
  text: string;
  author: string;
  rating: number;
  source: string;
  avatarUrl?: string;
  projectImageUrls?: string[];
  videoUrl?: string;
  videoThumbnailUrl?: string;
}

const { text, author, rating, source, avatarUrl, projectImageUrls, videoUrl, videoThumbnailUrl } = Astro.props;
const initial = (author || '?').charAt(0).toUpperCase();
const hasProjectImages = Array.isArray(projectImageUrls) && projectImageUrls.length > 0;
const coverImage = hasProjectImages ? projectImageUrls[0] : null;
const restImages = hasProjectImages && projectImageUrls.length > 1 ? projectImageUrls.slice(1) : [];
const isVideoReview = !!videoUrl;
---

<div class="flex flex-col rounded-none border border-neutral-200 bg-surface-elevated p-5 shadow-sm break-inside-avoid mb-4">
  <div class="flex text-amber-500 text-sm mb-2" aria-label={`${rating} out of 5 stars`}>
    {[1, 2, 3, 4, 5].map((i) => (
      <span class={i <= rating ? 'text-amber-500' : 'text-neutral-300'}>★</span>
    ))}
  </div>
  <p class="text-neutral-700 text-sm leading-relaxed mb-4 whitespace-pre-line">{text}</p>
  {isVideoReview && videoUrl && (
    <div class="-mx-5 mb-4 border-y border-neutral-200 bg-black">
      <video
        class="w-full aspect-video max-h-[360px] object-cover"
        poster={videoThumbnailUrl || ''}
        controls
        preload="metadata"
        playsinline
      >
        <source src={videoUrl} type="video/mp4" />
      </video>
    </div>
  )}
  {!isVideoReview && coverImage && (
    <div class="-mx-5 mb-4" aria-label="Project photos">
      <img src={coverImage} alt="" class="w-full aspect-video object-cover" width="400" height="225" loading="lazy" decoding="async" />
      {restImages.length > 0 && (
        <div class="mt-1 grid grid-cols-2 gap-0.5">
          {restImages.map((url) => (
            <img src={url} alt="" class="w-full aspect-video object-cover" width="200" height="113" loading="lazy" decoding="async" />
          ))}
        </div>
      )}
    </div>
  )}
  <footer class="flex items-center gap-3 pt-2 border-t border-neutral-100">
    {avatarUrl ? (
      <img src={avatarUrl} alt="" class="h-10 w-10 rounded-full object-cover" width="40" height="40" loading="lazy" decoding="async" />
    ) : (
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-neutral-200 text-sm font-semibold text-neutral-600" aria-hidden="true">{initial}</span>
    )}
    <div>
      <p class="font-semibold text-neutral-800 text-sm">{author}</p>
      <p class="text-xs text-neutral-500">{source}</p>
    </div>
  </footer>
</div>
