---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

interface VideoReview {
  videoUrl?: string;
  videoThumbnailUrl?: string;
}

interface JosephReview {
  text: string;
  author: string;
  rating: number;
  source: string;
  avatarUrl?: string;
}

interface Props {
  videoReview: VideoReview | null;
  josephReview: JosephReview | null;
}

const { videoReview, josephReview } = Astro.props;

const avatarGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/avatars/*.{jpg,jpeg,png,webp}');

const resolveAvatar = async (filename: string): Promise<string | undefined> => {
  if (!filename) return undefined;
  const key = Object.keys(avatarGlob).find((k) => k.endsWith(filename));
  if (!key || typeof avatarGlob[key] !== 'function') return undefined;
  const mod = await (avatarGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 40, height: 40, format: 'avif' });
  return img.src;
};

const resolvedJosephAvatar = josephReview?.avatarUrl ? await resolveAvatar(josephReview.avatarUrl) : undefined;
---

<section class="py-10 sm:py-12 lg:py-14 bg-surface border-t border-neutral-200" aria-label="Featured customer story">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <header class="mb-7 sm:mb-9 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-1">Featured Customer</p>
        <h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-bold text-neutral-900 tracking-tight">
          The Leman Family&apos;s Deck Story
        </h2>
      </div>
      <p class="text-xs sm:text-[11px] text-neutral-600 max-w-md">
        A flagship project that shows what it looks like when design, build quality, and communication all come together.
      </p>
    </header>

    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      {videoReview?.videoUrl && (
        <div class="space-y-3 lg:pr-4">
          <div class="mx-auto w-full max-w-[420px] rounded-none border border-neutral-200 bg-black shadow-sm overflow-hidden">
            <video
              class="w-full aspect-9/16 object-cover bg-black"
              controls
              preload="metadata"
              playsinline
              poster={videoReview.videoThumbnailUrl || ''}
            >
              <source src={videoReview.videoUrl} type="video/mp4" />
            </video>
          </div>
          <p class="text-xs text-neutral-600">
            Hear directly from the homeowner about what it was like to work with Deck Masters on this project.
          </p>
        </div>
      )}

      <div class="space-y-4 lg:pl-4">
        {josephReview && (
          <article class="rounded-none border border-neutral-200 bg-surface-elevated p-5 shadow-sm">
            <div class="flex text-amber-500 text-sm mb-2" aria-label={`${josephReview.rating} out of 5 stars`}>
              {[1, 2, 3, 4, 5].map((i) => (
                <span class={i <= josephReview.rating ? 'text-amber-500' : 'text-neutral-300'}>★</span>
              ))}
            </div>
            <p class="text-neutral-700 text-sm leading-relaxed mb-4 whitespace-pre-line">{josephReview.text}</p>
            <footer class="flex items-center gap-3 pt-2 border-t border-neutral-100">
              {resolvedJosephAvatar ? (
                <img
                  src={resolvedJosephAvatar}
                  alt=""
                  class="h-10 w-10 rounded-full object-cover"
                  width="40"
                  height="40"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-neutral-200 text-sm font-semibold text-neutral-600" aria-hidden="true">
                  {josephReview.author.charAt(0).toUpperCase()}
                </span>
              )}
              <div>
                <p class="font-semibold text-neutral-800 text-sm">{josephReview.author}</p>
                <p class="text-xs text-neutral-500">{josephReview.source}</p>
              </div>
            </footer>
          </article>
        )}

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 text-[10px] sm:text-xs text-neutral-500">
          <div class="h-20 sm:h-24 bg-neutral-50 border border-dashed border-neutral-300 flex items-center justify-center text-center px-3">
            Project photos coming soon
          </div>
          <div class="h-20 sm:h-24 bg-neutral-50 border border-dashed border-neutral-300 flex items-center justify-center text-center px-3">
            Before &amp; after coming soon
          </div>
          <div class="h-20 sm:h-24 bg-neutral-50 border border-dashed border-neutral-300 flex items-center justify-center text-center px-3">
            Night lighting view coming soon
          </div>
          <div class="h-20 sm:h-24 bg-neutral-50 border border-dashed border-neutral-300 flex items-center justify-center text-center px-3">
            Close-up details coming soon
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

