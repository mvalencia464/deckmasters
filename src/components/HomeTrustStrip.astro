---
/**
 * Trust badges row — same content pattern as /copywriting-library (checkmarks + short lines).
 */
import { homepageTrustStripItems } from '../data/copywritingLibrary';
---

<section class="border-b border-neutral-200 bg-surface-muted/80 py-8 sm:py-10" aria-label="Trust highlights">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ul class="grid gap-4 sm:grid-cols-3 sm:gap-6" role="list">
      {
        homepageTrustStripItems.map((item) => (
          <li class="flex gap-3 rounded-sm border border-neutral-200 bg-white px-4 py-3 text-sm text-neutral-800 shadow-sm">
            <span class="text-accent font-bold shrink-0" aria-hidden="true">
              ✓
            </span>
            <span>
              <span class="font-bold text-neutral-900">{item.kicker}: </span>
              {item.line}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
