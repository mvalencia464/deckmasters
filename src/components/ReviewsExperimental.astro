---
/**
 * Reviews masonry: More Good Reviews data (reviews.json), refreshed at build via fetch-mgr-reviews.js.
 * Avatar: MGR provides reviewer.profile URL only (HTTPS) — used as-is.
 * `images[]` (local filenames in src/assets/review-images): merged at build from legacy
 * `google-reviews.json` when author + rating + text match; new-only MGR reviews have no images.
 */
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import GoogleReviewCard from './GoogleReviewCard.astro';

const data = (await import('../data/reviews.json')).default;
const rawReviews = data?.rawReviews ?? [];

const mgrGoogleReviews = rawReviews.filter((r: { source?: string; rating?: number }) =>
  String(r.source ?? '').toLowerCase().includes('google') && Number(r.rating) > 0
);
const googleReviewCount = mgrGoogleReviews.length;
const averageRating = googleReviewCount
  ? (
      mgrGoogleReviews.reduce((a: number, r: { rating?: number }) => a + Number(r.rating), 0) /
      googleReviewCount
    ).toFixed(1)
  : '0';

const withText = rawReviews.filter((r: { text?: string }) => (r.text || '').trim().length > 0);
let displayReviews = withText.slice();

const ericaIndex = displayReviews.findIndex(
  (r: { videoUrl?: string; author?: string }) =>
    !!r.videoUrl && /erica\s+le?hman/i.test(String(r.author ?? ''))
);
if (ericaIndex > 0) {
  const [ericaReview] = displayReviews.splice(ericaIndex, 1);
  displayReviews.unshift(ericaReview);
}
const oneStarIndex = displayReviews.findIndex(
  (r: { author?: string; rating?: number }) => r.author === 'Matthew Moglianesi' && r.rating === 1
);
if (oneStarIndex > -1) {
  const [oneStar] = displayReviews.splice(oneStarIndex, 1);
  const insertIndex = Math.floor(displayReviews.length * 0.65);
  displayReviews.splice(insertIndex, 0, oneStar);
}

const avatarGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/avatars/*.{jpg,jpeg,png,webp}');
const reviewImagesGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/review-images/*.{jpg,jpeg,png,webp}');

const isRemoteOrPublicPath = (ref: string) => {
  const t = ref.trim();
  return /^https?:\/\//i.test(t) || t.startsWith('/');
};

const resolveAvatar = async (ref: string): Promise<string | undefined> => {
  if (!ref) return undefined;
  if (isRemoteOrPublicPath(ref)) return ref.trim();
  const key = Object.keys(avatarGlob).find((k) => k.endsWith(ref));
  if (!key || typeof avatarGlob[key] !== 'function') return undefined;
  const mod = await (avatarGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 40, height: 40, format: 'avif' });
  return img.src;
};

const resolveReviewImage = async (ref: string): Promise<string | undefined> => {
  if (!ref) return undefined;
  if (isRemoteOrPublicPath(ref)) return ref.trim();
  const key = Object.keys(reviewImagesGlob).find((k) => k.endsWith(ref));
  if (!key || typeof reviewImagesGlob[key] !== 'function') return undefined;
  const mod = await (reviewImagesGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 160, height: 120, format: 'avif' });
  return img.src;
};

const reviewsWithAvatars = await Promise.all(
  displayReviews.map(
    async (
      r: {
        text: string;
        author: string;
        rating: number;
        source: string;
        avatarUrl?: string;
        images?: string[];
        videoUrl?: string;
        videoThumbnailUrl?: string;
      }
    ) => {
      const avatarUrl = r.avatarUrl ? await resolveAvatar(r.avatarUrl) : undefined;
      const images = r.images ?? [];
      const projectImageUrls =
        images.length > 0
          ? (await Promise.all(images.map((f: string) => resolveReviewImage(f)))).filter((u): u is string => !!u)
          : undefined;
      return { ...r, avatarUrl, projectImageUrls };
    }
  )
);
---

<section id="reviews" class="reviews-diagonal-bg py-12 sm:py-16 lg:py-24 border-t border-neutral-200" aria-label="Reviews">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Reviews</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">What Anchorage Is Saying.</h2>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <div class="flex items-center gap-2">
          <span class="text-amber-500 text-lg" aria-hidden="true">★★★★★</span>
          <span class="font-bold text-neutral-800">{averageRating}</span>
          <span class="text-neutral-500 uppercase font-semibold">Average</span>
        </div>
        <span class="text-neutral-300">|</span>
        <span class="text-neutral-600 font-semibold">{googleReviewCount} Google Reviews</span>
        <a href="https://www.google.com/search?q=deckmasters+anchorage+reviews" target="_blank" rel="noopener" class="text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider">See All Google Reviews →</a>
      </div>
    </div>
    <div class="columns-1 md:columns-4 column-gap-4">
      {reviewsWithAvatars.map((r) => (
        <GoogleReviewCard
          text={r.text}
          author={r.author}
          rating={r.rating}
          source={r.source ?? 'Google'}
          avatarUrl={r.avatarUrl}
          projectImageUrls={r.projectImageUrls}
          videoUrl={r.videoUrl}
          videoThumbnailUrl={r.videoThumbnailUrl}
        />
      ))}
    </div>
  </div>
</section>
