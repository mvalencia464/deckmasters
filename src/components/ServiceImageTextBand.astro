---
import type { ServiceVisualBand } from '../data/servicePageVisualBands';
import VocQuoteCard from './VocQuoteCard.astro';
import ProjectPicture from './ProjectPicture.astro';

interface Props {
  band: ServiceVisualBand;
}

const { band } = Astro.props;
const { image, reverse, eyebrow, headline, paragraphs, proof } = band;
---

<section
  class="border-y border-neutral-200 bg-surface-muted"
  aria-label="Project context"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-8 lg:gap-12 lg:grid-cols-2 lg:items-center">
      <div
        class:list={[
          'overflow-hidden border border-neutral-200 shadow-sm bg-neutral-100',
          reverse && 'lg:order-2',
        ]}
      >
        <div class="aspect-[4/3] w-full">
          <ProjectPicture
            src={image}
            alt=""
            pictureClass="block h-full w-full"
            imgClass="h-full w-full object-cover"
            width={960}
            height={720}
            loading="lazy"
          />
        </div>
      </div>
      <div class:list={['min-w-0', reverse && 'lg:order-1']}>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange">{eyebrow}</p>
        <h2 class="mt-3 font-display text-2xl md:text-3xl font-bold uppercase tracking-tight text-neutral-800">
          {headline}
        </h2>
        <div class="mt-5 space-y-4 text-neutral-600 leading-relaxed">
          {paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>
        {
          proof && (
            <div class="mt-8">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-3">Homeowners said it</p>
              <VocQuoteCard snippet={proof} compact />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
