---
interface Props {
  title: string;
  description?: string;
  href?: string;
  imageUrl?: string;
}

const { title, description, href = '/services', imageUrl } = Astro.props;
---

<article class="group rounded-none border border-neutral-200 bg-surface-elevated overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
  <a href={href} class="block focus-ring">
    {imageUrl ? (
      <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
        <img
          src={imageUrl}
          alt=""
          width={400}
          height={300}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[4/3] bg-wood-light flex items-center justify-center border-b border-neutral-100" aria-hidden="true">
        <span class="text-3xl text-brand-orange/40">◆</span>
      </div>
    )}
    <div class="p-5 border-t border-neutral-100">
      <h3 class="text-lg font-semibold text-neutral-800 group-hover:text-brand-orange transition-colors duration-200">{title}</h3>
      {description && <p class="mt-2 text-sm text-neutral-600">{description}</p>}
    </div>
  </a>
</article>
