---
interface Props {
  title: string;
  description?: string;
  href?: string;
  imageUrl?: string;
}

const { title, description, href = '/services', imageUrl } = Astro.props;
---

<article class="group rounded-2xl border border-neutral-200 bg-surface-elevated overflow-hidden transition-shadow duration-200 hover:shadow-lg">
  <a href={href} class="block focus-ring rounded-2xl">
    {imageUrl ? (
      <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
        <img
          src={imageUrl}
          alt=""
          width={400}
          height={300}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[4/3] bg-wood-light flex items-center justify-center" aria-hidden="true">
        <span class="text-4xl text-wood-muted">◆</span>
      </div>
    )}
    <div class="p-6">
      <h3 class="text-lg font-semibold text-neutral-800 group-hover:text-accent transition-colors duration-200">{title}</h3>
      {description && <p class="mt-2 text-sm text-neutral-600">{description}</p>}
    </div>
  </a>
</article>
