---
/**
 * Featured project: hero teaser + flagship project images.
 * Collage images are manually selected from a single flagship project.
 */

interface Props {
  josephReview: unknown | null;
}

const {} = Astro.props;
const projectImages = [
  '/projects/001-aerial-wraparound.avif',
  '/projects/002-aerial-view-new.avif',
  '/projects/003-aerial-detail.avif',
  '/projects/004-aerial-landscape.avif',
  '/projects/005-aerial-wide.avif',
  '/projects/006-aerial-composite.avif',
  '/projects/007-aerial-luxury.avif',
  '/projects/008-aerial-elevated.avif',
  '/projects/009-masterpiece-main.avif',
];
const hasProjectImages = projectImages.length > 0;
---

<section id="featured-project" class="reviews-diagonal-bg py-12 sm:py-16 lg:py-24 border-t border-neutral-200" aria-label="Featured project">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Featured Project</p>
    <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight mb-8">Our Featured Project.</h2>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
      <a
        href="/featured-project"
        class="group lg:col-span-2 rounded-none border border-neutral-200 bg-neutral-200 overflow-hidden shadow-sm aspect-[9/16] w-full max-w-sm mx-auto lg:mx-0 focus-ring"
      >
        <div class="relative h-full w-full">
          <img
            src={projectImages[0]}
            alt="Watch the full featured deck build"
            class="w-full h-full object-cover"
            width="540"
            height="960"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/35 group-hover:bg-black/45 transition-colors flex flex-col items-center justify-center gap-3 text-center text-neutral-50 px-6">
            <div class="flex items-center justify-center h-14 w-14 rounded-full bg-white/10 border border-white/60 shadow-lg">
              <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" fill="none">
                <circle cx="12" cy="12" r="11" class="stroke-current" stroke-width="1.5" />
                <path d="M10 8.5L16 12L10 15.5V8.5Z" fill="currentColor" />
              </svg>
            </div>
            <div>
              <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-orange">Watch The Build</p>
              <p class="mt-1 text-sm sm:text-base font-semibold">See a full Deck Masters project walkthrough.</p>
            </div>
          </div>
        </div>
      </a>
      <div class="lg:col-span-3">
        {hasProjectImages && (
          <div class="mt-6">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {projectImages.map((url) => (
                <figure class="overflow-hidden rounded-sm border border-neutral-200 bg-neutral-100">
                  <img
                    src={url}
                    alt=""
                    class="w-full h-full object-cover aspect-[4/3]"
                    width="360"
                    height="270"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              ))}
            </div>
            <p class="mt-5">
              <a
                href="/featured-project"
                class="inline-flex items-center text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider"
              >
                View Featured Project →
              </a>
            </p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
