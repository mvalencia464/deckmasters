---
import { riskReversalLines, trustBadges } from '../data/copywritingLibrary';

/** First three trust badges — full VOC lines, customer-safe */
const badges = trustBadges.slice(0, 3);
---

<section class="border-y border-neutral-200 bg-surface-muted/90 py-12 lg:py-14" aria-labelledby="service-trust-heading">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 id="service-trust-heading" class="font-display text-xl md:text-2xl font-bold uppercase tracking-tight text-neutral-900">
      What you can expect from the first call
    </h2>
    <ul class="mt-6 space-y-3 list-none p-0 m-0" role="list">
      {
        riskReversalLines.map((line) => (
          <li class="flex gap-3 text-neutral-700 text-sm sm:text-base leading-relaxed">
            <span class="text-accent font-bold shrink-0" aria-hidden="true">
              ✓
            </span>
            <span>{line}</span>
          </li>
        ))
      }
    </ul>
    <p class="mt-8 text-xs font-bold uppercase tracking-[0.2em] text-neutral-500">Homeowners also mention</p>
    <div class="mt-3 grid gap-3 sm:grid-cols-3">
      {
        badges.map((b) => (
          <div class="border border-neutral-200 bg-white p-4 text-center shadow-sm">
            <p class="text-xs text-neutral-700 leading-snug">{b}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
