---
/**
 * Homepage hero: social-proof angle (five-star reviews, trust, reliability).
 * Vibrant background image on desktop, dark overlay, light text; mobile gradient + framed image.
 */
import { Image } from 'astro:assets';
import QuoteForm from './QuoteForm.astro';
import SocialProofPill from './SocialProofPill.astro';
import vibrantImg from '../assets/vibrant.webp';
import { heroCopy } from '../data/homepageCopy';

const hero = heroCopy();
---

<section class="relative min-h-[min(85vh,800px)] overflow-hidden bg-neutral-900" aria-label="Hero">
  <!-- Library-style ambient glow (matches admin copywriting library hero treatment) -->
  <div
    class="pointer-events-none absolute inset-0 z-[2] opacity-70 lg:opacity-100"
    style="background: radial-gradient(ellipse 80% 55% at 15% 10%, rgba(193,78,10,0.22) 0%, transparent 50%), radial-gradient(ellipse 65% 45% at 85% 95%, rgba(13,148,136,0.14) 0%, transparent 48%)"
    aria-hidden="true"
  >
  </div>
  <!-- Desktop Background -->
  <div class="absolute inset-0 z-0 hidden lg:block" aria-hidden="true">
    <Image
      src={vibrantImg}
      alt="Vibrant Deck Project"
      width={1920}
      height={1080}
      widths={[640, 960, 1280, 1536, 1920]}
      sizes="100vw"
      decoding="async"
      loading="eager"
      fetchpriority="high"
      class="w-full h-full object-cover"
    />
  </div>
  <!-- Overlays (Desktop) -->
  <div class="absolute inset-0 z-[1] bg-neutral-900/55 pointer-events-none hidden lg:block" aria-hidden="true" />
  <div
    class="absolute inset-0 z-[1] pointer-events-none hidden lg:block"
    aria-hidden="true"
    style="background-image: linear-gradient(to right, rgba(0,0,0,0.6) 0%, transparent 50%), linear-gradient(to left, rgba(0,0,0,0.4) 0%, transparent 60%);"
  />

  <!-- Mobile Background/Gradient -->
  <div class="absolute inset-0 z-0 lg:hidden bg-gradient-to-b from-neutral-900 via-neutral-900 to-black" aria-hidden="true" />

  <div class="relative z-[3] mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 md:py-16 lg:py-20">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
      <!-- Left: copy (screenshot standard) -->
      <div class="w-full lg:w-3/5 flex-shrink-0">
        <!-- Mobile: photo first; desktop uses full-bleed background image -->
        <div class="lg:hidden mb-8 -mx-4 sm:mx-0 overflow-hidden shadow-2xl border-y border-neutral-800 sm:border sm:rounded-none">
          <Image
            src={vibrantImg}
            alt="Vibrant Deck Project"
            width={800}
            height={533}
            widths={[400, 640, 800, 960, 1280]}
            sizes="100vw"
            decoding="async"
            loading="eager"
            fetchpriority="high"
            class="w-full aspect-video object-cover"
          />
        </div>
        <h1 class="max-w-4xl mb-6">
          <span class="block font-display text-xs sm:text-sm font-bold uppercase tracking-[0.25em] text-brand-orange mb-4 drop-shadow-md">
            {hero.h1Seo}
          </span>
          <span class="block font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-[1.08] font-bold text-white uppercase tracking-tight drop-shadow-lg">
            {hero.h1Quote}
          </span>
        </h1>
        <p class="max-w-xl text-neutral-200 text-lg md:text-xl leading-relaxed mb-6 drop-shadow">
          {hero.subhead}
        </p>
        <p class="max-w-lg text-neutral-300 text-base mb-6 uppercase tracking-wide drop-shadow">
          {hero.support}
        </p>
        <SocialProofPill />
      </div>

      <!-- Right: form card (reference style: white, dark border, shadow) -->
      <div class="w-full lg:w-2/5 flex-shrink-0 lg:sticky lg:top-28" id="quote">
        <div class="bg-neutral-900 border-[3px] border-neutral-700 p-8 md:p-10 rounded-none shadow-xl shadow-black/40">
          <QuoteForm />
        </div>
      </div>
    </div>
  </div>
</section>
