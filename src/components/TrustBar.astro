---
import { homepageTrustStripItems } from '../data/copywritingLibrary';
---

<section class="bg-neutral-50 border-t border-neutral-200 py-8" aria-label="Trust highlights">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ul class="grid gap-6 sm:grid-cols-3 sm:gap-8 list-none p-0 m-0" role="list">
      {
        homepageTrustStripItems.map((item) => (
          <li class="text-center sm:text-left">
            <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-orange">{item.kicker}</p>
            <p class="mt-1.5 text-xs sm:text-sm text-neutral-600 leading-snug font-medium">{item.line}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
