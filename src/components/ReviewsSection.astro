---
/**
 * Reviews masonry: DataForSEO → google-reviews.json (sync at build via scripts/sync-reviews.js).
 * Curated video rows from curated-video-reviews.json (Erica testimonial, first = top-left column).
 */
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';
import GoogleReviewCard from './GoogleReviewCard.astro';

const googleData = (await import('../data/google-reviews.json')).default;
const curatedData = (await import('../data/curated-video-reviews.json')).default;
const googleReviews = googleData?.rawReviews ?? [];
const curated = curatedData?.rawReviews ?? [];

const isEricaVideoReview = (r: { videoUrl?: string; author?: string; source?: string }) =>
  !!r.videoUrl &&
  (/erica\s+le?hman/i.test(String(r.author ?? '')) ||
    /video testimonial/i.test(String(r.source ?? '')));

type MasonryReview = {
  text: string;
  author: string;
  rating: number;
  source: string;
  date?: string;
  avatarUrl?: string;
  images?: string[];
  videoUrl?: string;
  videoThumbnailUrl?: string;
  captionsUrl?: string;
};

const ericaVideoReview = curated.find(isEricaVideoReview) as MasonryReview | undefined;

const withText = googleReviews.filter((r: { text?: string }) => (r.text || '').trim().length > 0) as MasonryReview[];
let displayReviews: MasonryReview[] = withText.filter(
  (r) => !isEricaVideoReview(r)
);
if (ericaVideoReview) {
  displayReviews.unshift(ericaVideoReview);
}
const oneStarIndex = displayReviews.findIndex((r) => r.author === 'Matthew Moglianesi' && r.rating === 1);
if (oneStarIndex > -1) {
  const [oneStar] = displayReviews.splice(oneStarIndex, 1);
  const insertIndex = Math.floor(displayReviews.length * 0.65);
  displayReviews.splice(insertIndex, 0, oneStar);
}

const avatarGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/avatars/*.{jpg,jpeg,png,webp}');
const reviewImagesGlob = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/review-images/*.{jpg,jpeg,png,webp}'
);

const isRemoteOrPublicPath = (ref: string) => {
  const t = ref.trim();
  return /^https?:\/\//i.test(t) || t.startsWith('/');
};

const resolveAvatar = async (ref: string): Promise<string | undefined> => {
  if (!ref) return undefined;
  if (isRemoteOrPublicPath(ref)) return ref.trim();
  const key = Object.keys(avatarGlob).find((k) => k.endsWith(ref));
  if (!key || typeof avatarGlob[key] !== 'function') return undefined;
  const mod = await (avatarGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 40, height: 40, format: 'avif' });
  return img.src;
};

const resolveReviewImage = async (ref: string): Promise<string | undefined> => {
  if (!ref) return undefined;
  if (isRemoteOrPublicPath(ref)) return ref.trim();
  const key = Object.keys(reviewImagesGlob).find((k) => k.endsWith(ref));
  if (!key || typeof reviewImagesGlob[key] !== 'function') return undefined;
  const mod = await (reviewImagesGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 160, height: 120, format: 'avif' });
  return img.src;
};

const reviewsWithAvatars = await Promise.all(
  displayReviews.map(
    async (r: MasonryReview) => {
      const avatarUrl = r.avatarUrl ? await resolveAvatar(r.avatarUrl) : undefined;
      const images = r.images ?? [];
      const projectImageUrls =
        images.length > 0
          ? (await Promise.all(images.map((f: string) => resolveReviewImage(f)))).filter((u): u is string => !!u)
          : undefined;
      const isVideo = !!r.videoUrl;
      const sourceLine = isVideo
        ? (r.source ?? 'Google')
        : r.date
          ? `Google · ${r.date}`
          : 'Google';
      return { ...r, avatarUrl, projectImageUrls, sourceLine };
    }
  )
);
---

<section id="reviews" class="reviews-diagonal-bg py-12 sm:py-16 lg:py-24 border-t border-neutral-200" aria-label="Reviews">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Reviews</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">What Anchorage Is Saying.</h2>
      </div>
      <a
        href="https://www.google.com/search?q=deckmasters+anchorage+reviews"
        target="_blank"
        rel="noopener"
        class="shrink-0 text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider sm:mb-1"
      >
        See all on Google →
      </a>
    </div>
    <div class="columns-1 md:columns-4 column-gap-4">
      {
        reviewsWithAvatars.map((r) => (
          <div class="break-inside-avoid">
            <GoogleReviewCard
              text={r.text}
              author={r.author}
              rating={r.rating}
              source={r.sourceLine}
              avatarUrl={r.avatarUrl}
              projectImageUrls={r.projectImageUrls}
              videoUrl={r.videoUrl}
              videoThumbnailUrl={r.videoThumbnailUrl}
              captionsUrl={r.captionsUrl}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
