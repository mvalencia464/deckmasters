---
/**
 * Homepage-only: verbatim “gems” + even-if objection lines from the copywriting library.
 * Internal methodology labels stay on /copywriting-library only.
 */
import {
  homepageFeaturedVerbatims,
  homepageEvenIfLines,
} from '../data/copywritingLibrary';
---

<section class="py-14 sm:py-16 lg:py-20 bg-white border-t border-neutral-200" aria-labelledby="verbatim-gems-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Real homeowners</p>
    <h2 id="verbatim-gems-heading" class="font-display text-3xl md:text-4xl font-bold text-neutral-800 uppercase tracking-tight max-w-3xl">
      The kind of thing people tell their neighbors
    </h2>
    <p class="mt-3 text-neutral-600 max-w-2xl">
      Verbatim lines from reviews — not invented taglines.
    </p>
    <ul class="mt-10 grid gap-6 md:grid-cols-3 list-none p-0 m-0" role="list">
      {
        homepageFeaturedVerbatims.map((v) => (
          <li class="border border-neutral-200 bg-surface p-6 shadow-sm border-l-4 border-l-brand-orange flex flex-col">
            <blockquote class="text-neutral-800 leading-relaxed grow text-sm sm:text-base">“{v.quote}”</blockquote>
            <p class="mt-4 text-xs font-bold uppercase tracking-wider text-neutral-500">— {v.author}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<section class="py-14 sm:py-16 bg-neutral-900 text-white border-t border-neutral-800" aria-labelledby="even-if-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-orange-300/90 mb-2">If you’re on the fence</p>
    <h2 id="even-if-heading" class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight max-w-3xl">
      You can still move forward
    </h2>
    <ul class="mt-8 space-y-4 max-w-4xl list-none p-0 m-0" role="list">
      {
        homepageEvenIfLines.map((line) => (
          <li class="border-l-2 border-brand-orange pl-4 text-neutral-200 leading-relaxed text-sm sm:text-base">
            {line.split(/\*\*/).map((part, i) => (i % 2 === 1 ? <strong class="text-white">{part}</strong> : part))}
          </li>
        ))
      }
    </ul>
  </div>
</section>
