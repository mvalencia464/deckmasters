---
/**
 * Quote form — submits to /api/submit-quote (GHL). Optional service line (Contact page / Prompt 7).
 */
import CustomerSuccessManager from './CustomerSuccessManager.astro';
import { CONTACT_FORM_OTHER_OPTION, contactFormServiceGroups } from '../data/contactFormServiceOptions';
import { publicHomepageHero, riskReversalLines } from '../data/copywritingLibrary';

interface Props {
  /** Core30 Prompt 7: category + core hub dropdown on Contact */
  includeServiceSelect?: boolean;
}

const { includeServiceSelect = false } = Astro.props;

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';

const inputClass =
  'w-full border-2 border-neutral-700 bg-neutral-900/80 p-3 text-sm font-medium text-neutral-100 placeholder-neutral-500 focus:border-brand-orange focus:ring-0 outline-none rounded-none';

const reviewData = (await import('../data/google-reviews.json')).default;
const reviewRaw = reviewData?.rawReviews ?? [];
const googleReviews = reviewRaw.filter((r: { source?: string; rating?: number }) =>
  String(r.source ?? '').toLowerCase().includes('google') && Number(r.rating) > 0
);
const googleReviewCount = googleReviews.length;
const googleAverageRating = googleReviews.length
  ? (googleReviews.reduce((a: number, r: { rating?: number }) => a + Number(r.rating), 0) / googleReviewCount).toFixed(1)
  : '0';
---

<form
  id="quote-form"
  class="space-y-4 rounded-none text-neutral-100"
  aria-label="Request a quote"
>
  <h2 class="font-display text-3xl font-bold uppercase mb-1 text-center text-neutral-50">Request Estimate</h2>
  <p class="text-center text-[10px] font-bold tracking-widest text-neutral-400 mb-3 border-b border-neutral-700 pb-4">
    THE NO-SURPRISE GUARANTEE
  </p>
  <p class="text-center text-xs text-neutral-400 leading-relaxed mb-8 px-1">{riskReversalLines[0]}</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <label class="block">
      <span class="sr-only">Full Name</span>
      <input type="text" name="name" required autocomplete="name" class={inputClass} placeholder="Full Name*" />
    </label>
    <label class="block">
      <span class="sr-only">Phone Number</span>
      <input type="tel" name="phone" required autocomplete="tel" class={inputClass} placeholder="Phone Number*" />
    </label>
  </div>

  <label class="block">
    <span class="sr-only">Email</span>
    <input type="email" name="email" required autocomplete="email" class={inputClass} placeholder="Email Address*" />
  </label>

  <label class="block">
    <span class="sr-only">Project address</span>
    <input
      type="text"
      id="project-address"
      name="projectAddress"
      required
      autocomplete="street-address"
      class={inputClass}
      placeholder="Project address *"
    />
  </label>
  <input type="hidden" name="addressLine1" id="address-line1" value="" />
  <input type="hidden" name="addressCity" id="address-city" value="" />
  <input type="hidden" name="addressState" id="address-state" value="" />
  <input type="hidden" name="addressZip" id="address-zip" value="" />
  <input type="hidden" name="addressCountry" id="address-country" value="" />

  {
    includeServiceSelect && (
      <label class="block">
        <span class="sr-only">Service needed</span>
        <select name="serviceType" required class={`${inputClass} appearance-none bg-[url('data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 fill=%27none%27 viewBox=%270 0 24 24%27 stroke=%27%239ca3af%27%3E%3Cpath stroke-linecap=%27round%27 stroke-linejoin=%27round%27 stroke-width=%272%27 d=%27M19 9l-7 7-7-7%27/%3E%3C/svg%3E')] bg-[length:1.25rem] bg-[right_0.75rem_center] bg-no-repeat pr-10`}>
          <option value="" disabled selected>
            Service needed *
          </option>
          {contactFormServiceGroups.map((group) => (
            <optgroup label={group.label}>
              {group.options.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </optgroup>
          ))}
          <option value={CONTACT_FORM_OTHER_OPTION}>{CONTACT_FORM_OTHER_OPTION}</option>
        </select>
      </label>
    )
  }

  <label class="block">
    <span class="sr-only">Project description</span>
    <textarea name="projectDescription" rows={1} required class={inputClass} placeholder="Project description *"></textarea>
  </label>

  <div class="block">
    <div id="dropzone" class="border-2 border-dashed border-neutral-600 p-4 text-center cursor-pointer hover:border-brand-orange hover:bg-neutral-800 transition-colors">
      <p class="text-xs text-neutral-400" id="dropzone-text">Click or drag a photo of your project area (optional)</p>
      <input type="file" id="photo-upload" name="photo" accept="image/*" class="hidden" />
    </div>
  </div>

  <div class="mt-4 space-y-3 text-[11px] leading-snug text-neutral-300">
    <label class="flex items-start gap-2">
      <input
        type="checkbox"
        name="termsConsent"
        required
        class="mt-0.5 h-3.5 w-3.5 rounded-none border border-neutral-600 bg-neutral-900 text-brand-orange focus:ring-1 focus:ring-brand-orange"
      />
      <span>
        By checking this box I agree to Deck Masters&apos;{' '}
        <a href="/terms" class="underline hover:text-brand-orange">Terms</a> &amp;{' '}
        <a href="/privacy" class="underline hover:text-brand-orange">Privacy Policy</a> and consent to receive SMS messages
        about my project. Msg &amp; data rates may apply. Reply STOP to opt out. *
      </span>
    </label>

    <label class="flex items-start gap-2">
      <input
        type="checkbox"
        name="marketingConsent"
        class="mt-0.5 h-3.5 w-3.5 rounded-none border border-neutral-600 bg-neutral-900 text-brand-orange focus:ring-1 focus:ring-brand-orange"
      />
      <span>
        I consent to receive recurring automated marketing texts (promos, offers) from Deck Masters. Consent is not required
        to purchase. Msg frequency varies. Msg &amp; data rates may apply. Reply STOP to cancel. *
      </span>
    </label>
  </div>

  <button
    type="submit"
    id="quote-submit-btn"
    class="w-full bg-brand-orange hover:bg-orange-800 text-white font-bold py-3 px-3 sm:py-4 sm:px-4 text-xs sm:text-sm uppercase tracking-wider flex items-center justify-center gap-1.5 transition-colors mt-6 shadow-md rounded-none focus-ring disabled:opacity-70 disabled:cursor-not-allowed"
  >
    <span class="sm:hidden">{publicHomepageHero.ctaPrimary} →</span>
    <span class="hidden sm:inline">{publicHomepageHero.ctaPrimary} →</span>
  </button>

  <p class="text-xs text-neutral-400 mt-4">
    By submitting you agree to be contacted about your project. We do not share your information.
  </p>

  <div class="mt-8 flex items-center justify-center gap-2">
    <span class="flex items-center gap-0.5 text-brand-orange text-sm" aria-hidden="true">★ ★ ★ ★ ★</span>
    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wider">
      {googleAverageRating}, {googleReviewCount} Google Reviews
    </span>
  </div>

  <p id="form-message" class="hidden text-sm mt-2" role="status" aria-live="polite"></p>
</form>

<div id="quote-success-panel" class="hidden mt-6">
  <CustomerSuccessManager />
</div>

<style is:global>
  .pac-container {
    z-index: 10000;
  }
</style>

<script define:vars={{ googleMapsApiKey }}>
  function parseAddressComponents(components) {
    if (!components || !components.length) {
      return { line1: '', city: '', state: '', zip: '', country: '' };
    }
    const get = (type) => components.find((c) => c.types.includes(type));
    const streetNumber = get('street_number')?.long_name ?? '';
    const route = get('route')?.long_name ?? '';
    const line1 = [streetNumber, route].filter(Boolean).join(' ').trim();
    // locality is often missing for some addresses (e.g. CDPs, boroughs); try broader types
    const city =
      get('locality')?.long_name ??
      get('sublocality')?.long_name ??
      get('sublocality_level_1')?.long_name ??
      get('neighborhood')?.long_name ??
      get('administrative_area_level_3')?.long_name ??
      get('administrative_area_level_2')?.long_name ??
      '';
    const state = get('administrative_area_level_1')?.short_name ?? '';
    const zip = get('postal_code')?.long_name ?? '';
    const country = get('country')?.short_name ?? '';
    return { line1, city, state, zip, country };
  }

  function setHiddenAddress(parts) {
    const line1 = document.getElementById('address-line1');
    const city = document.getElementById('address-city');
    const state = document.getElementById('address-state');
    const zip = document.getElementById('address-zip');
    const country = document.getElementById('address-country');
    if (line1) line1.value = parts.line1;
    if (city) city.value = parts.city;
    if (state) state.value = parts.state;
    if (zip) zip.value = parts.zip;
    if (country) country.value = parts.country;
  }

  function loadGoogleMaps() {
    if (typeof google !== 'undefined' && google.maps?.places) {
      return Promise.resolve();
    }
    return new Promise((resolve, reject) => {
      const existing = document.querySelector('script[data-google-maps="places"]');
      if (existing) {
        existing.addEventListener('load', () => resolve());
        existing.addEventListener('error', () => reject(new Error('Google Maps script failed')));
        return;
      }
      const s = document.createElement('script');
      s.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(googleMapsApiKey)}&libraries=places&v=weekly`;
      s.async = true;
      s.defer = true;
      s.dataset.googleMaps = 'places';
      s.onload = () => resolve();
      s.onerror = () => reject(new Error('Google Maps script failed'));
      document.head.appendChild(s);
    });
  }

  function initProjectAddressAutocomplete() {
    if (!googleMapsApiKey) return;
    const input = document.getElementById('project-address');
    if (!input) return;

    loadGoogleMaps()
      .then(() => {
        const ac = new google.maps.places.Autocomplete(input, {
          types: ['address'],
          componentRestrictions: { country: 'us' },
          fields: ['address_components', 'formatted_address'],
        });
        ac.addListener('place_changed', () => {
          const place = ac.getPlace();
          if (!place.address_components?.length) return;
          const parts = parseAddressComponents(place.address_components);
          setHiddenAddress(parts);
          if (place.formatted_address) {
            input.value = place.formatted_address;
          }
        });
      })
      .catch(() => {});
  }

  initProjectAddressAutocomplete();
</script>

<script>
  import { trackFormLead } from "@/lib/zaraz-tracking";

  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('quote-submit-btn') as HTMLButtonElement | null;
  const messageEl = document.getElementById('form-message') as HTMLParagraphElement | null;
  const successPanel = document.getElementById('quote-success-panel') as HTMLDivElement | null;
  const dropzone = document.getElementById('dropzone') as HTMLDivElement | null;
  const photoUpload = document.getElementById('photo-upload') as HTMLInputElement | null;
  const dropzoneText = document.getElementById('dropzone-text') as HTMLParagraphElement | null;

  if (form && messageEl) {
    const formEl = form as HTMLFormElement;

    if (dropzone && photoUpload && dropzoneText) {
      dropzone.addEventListener('click', () => photoUpload.click());
      
      photoUpload.addEventListener('change', () => {
        if (photoUpload.files && photoUpload.files.length > 0) {
          dropzoneText.textContent = `Selected: ${photoUpload.files[0].name}`;
        }
      });

      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('border-brand-orange', 'bg-neutral-800');
      });

      dropzone.addEventListener('dragleave', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-brand-orange', 'bg-neutral-800');
      });

      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-brand-orange', 'bg-neutral-800');
        if (e.dataTransfer && e.dataTransfer.files.length > 0) {
          photoUpload.files = e.dataTransfer.files;
          dropzoneText.textContent = `Selected: ${e.dataTransfer.files[0].name}`;
        }
      });
    }

    function showMessage(text: string, isError: boolean) {
      if (!messageEl) return;
      messageEl.textContent = text;
      messageEl.classList.remove('hidden', 'text-brand-orange', 'text-red-600');
      messageEl.classList.add(isError ? 'text-red-600' : 'text-brand-orange');
      if (successPanel) {
        if (isError) {
          successPanel.classList.add('hidden');
          formEl.classList.remove('hidden');
        } else {
          successPanel.classList.remove('hidden');
          formEl.classList.add('hidden');
        }
      }
    }

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!messageEl) return;
      if (submitBtn) submitBtn.disabled = true;
      messageEl.classList.add('hidden');
      if (successPanel) successPanel.classList.add('hidden');

      const getValue = (selector: string) => {
        const field = formEl.querySelector(selector) as
          | HTMLInputElement
          | HTMLTextAreaElement
          | HTMLSelectElement
          | null;
        return field?.value?.trim() || '';
      };

      const getChecked = (selector: string) => {
        const field = formEl.querySelector(selector) as HTMLInputElement | null;
        return !!field?.checked;
      };

      const buildFormData = () => {
        const payload = new FormData();
        payload.append('name', getValue('[name="name"]'));
        payload.append('email', getValue('[name="email"]'));
        payload.append('phone', getValue('[name="phone"]'));
        payload.append('projectAddress', getValue('[name="projectAddress"]'));
        payload.append('addressLine1', getValue('[name="addressLine1"]'));
        payload.append('addressCity', getValue('[name="addressCity"]'));
        payload.append('addressState', getValue('[name="addressState"]'));
        payload.append('addressZip', getValue('[name="addressZip"]'));
        payload.append('addressCountry', getValue('[name="addressCountry"]'));
        const serviceType = getValue('[name="serviceType"]');
        if (serviceType) payload.append('serviceType', serviceType);
        payload.append('projectDescription', getValue('[name="projectDescription"]'));
        payload.append('termsConsent', getChecked('[name="termsConsent"]') ? 'true' : '');
        payload.append('marketingConsent', getChecked('[name="marketingConsent"]') ? 'true' : '');
        const photoInput = document.getElementById('photo-upload') as HTMLInputElement | null;
        if (photoInput && photoInput.files && photoInput.files[0]) {
          payload.append('photo', photoInput.files[0]);
        }
        return payload;
      };

      const emailValue = getValue('[name="email"]');
      const nameValue = getValue('[name="name"]');

      // Fire Zaraz lead event (hashes email client-side → GA4 + Google Ads + Meta)
      trackFormLead(emailValue, nameValue).catch(() => {});

      const maxAttempts = 2;
      const retryDelayMs = (n: number) => 900 * (n + 1);

      try {
        for (let attempt = 0; attempt < maxAttempts; attempt++) {
          const res = await fetch('/api/submit-quote', {
            method: 'POST',
            body: buildFormData(),
          });
          const cfRay = res.headers.get('cf-ray') || '';
          const hdrReqId = res.headers.get('x-request-id') || '';
          const ct = res.headers.get('content-type') || '';

          if (ct.includes('application/json')) {
            const data = (await res.json().catch(() => ({}))) as {
              success?: boolean;
              message?: string;
              error?: string;
              requestId?: string;
            };
            if (res.ok && data.success) {
              showMessage(
                data.message || "Thank you! You're all set — meet your customer success manager below.",
                false
              );
              formEl.reset();
              const dropText = document.getElementById('dropzone-text');
              if (dropText) dropText.textContent = 'Click or drag a photo of your project area (optional)';
              break;
            }
            const ref = [data.requestId, hdrReqId, cfRay].filter(Boolean).join(' · ');
            const retryable =
              (res.status === 502 || res.status === 503 || res.status === 520) && attempt < maxAttempts - 1;
            if (retryable) {
              console.warn('[submit-quote] Retrying after CRM/upstream error', {
                status: res.status,
                attempt,
                ref,
              });
              await new Promise((r) => setTimeout(r, retryDelayMs(attempt)));
              continue;
            }
            showMessage(
              data.error ||
                (ref
                  ? `Something went wrong. Reference: ${ref}. Please try again or call us.`
                  : 'Something went wrong. Please try again or call us.'),
              true
            );
            break;
          }

          const bodySnippet = (await res.text().catch(() => '')).slice(0, 160);
          const retryable =
            (res.status === 502 || res.status === 503 || res.status === 520) && attempt < maxAttempts - 1;
          console.error('[submit-quote] Non-JSON response', {
            status: res.status,
            cfRay,
            hdrReqId,
            bodySnippet,
          });
          if (retryable) {
            await new Promise((r) => setTimeout(r, retryDelayMs(attempt)));
            continue;
          }
          const ref = [hdrReqId, cfRay].filter(Boolean).join(' · ') || 'n/a';
          showMessage(
            `We couldn’t reach the form service (error ${res.status}). Please try again or call us. Reference: ${ref}.`,
            true
          );
          break;
        }
      } catch (err) {
        console.error('[submit-quote] Network failure', err);
        showMessage('Network error. Please try again or call us.', true);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

  }
</script>
