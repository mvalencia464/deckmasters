---
/**
 * Drop-in test reviews section: reads src/data/dfs-test-reviews.json and
 * mirrors GoogleReviewCard layout (no video). Project photos use astro:assets <Image />.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const data = (await import('../data/dfs-test-reviews.json')).default;

type DfsReview = {
  review_id: string;
  rating: number;
  review_text: string;
  author_name: string;
  publish_date: string;
  local_avatar_path?: string;
  local_image_paths: string[];
};

const rawReviews: DfsReview[] = Array.isArray(data?.reviews) ? data.reviews : [];
const withText = rawReviews.filter((r) => (r.review_text || '').trim().length > 0);

const googleReviewCount = withText.filter((r) => Number(r.rating) > 0).length;
const averageRating = googleReviewCount
  ? (
      withText
        .filter((r) => Number(r.rating) > 0)
        .reduce((a, r) => a + Number(r.rating), 0) / googleReviewCount
    ).toFixed(1)
  : '0';

const reviewImagesGlob = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/review-images/test/*.{jpg,jpeg,png,webp}'
);
const avatarGlob = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/avatars/test/*.{jpg,jpeg,png,webp}'
);

function pathBasename(p: string) {
  const parts = p.replace(/\\/g, '/').split('/');
  return parts[parts.length - 1] ?? p;
}

async function resolveImageMetadata(
  relPath: string,
  glob: Record<string, () => Promise<{ default: ImageMetadata }>>
): Promise<ImageMetadata | undefined> {
  const file = pathBasename(relPath);
  const key = Object.keys(glob).find((k) => k.endsWith(file));
  if (!key || typeof glob[key] !== 'function') return undefined;
  const mod = await (glob[key] as () => Promise<{ default: ImageMetadata }>)();
  return mod?.default;
}

const reviewsResolved = await Promise.all(
  withText.map(async (r) => {
    const paths = Array.isArray(r.local_image_paths) ? r.local_image_paths : [];
    const metas = (
      await Promise.all(paths.map((p) => resolveImageMetadata(p, reviewImagesGlob)))
    ).filter((m): m is ImageMetadata => !!m);
    const coverImage = metas[0];
    const restImages = metas.length > 1 ? metas.slice(1) : [];
    const avatarPath = (r.local_avatar_path ?? '').trim();
    const avatarImage = avatarPath
      ? await resolveImageMetadata(avatarPath, avatarGlob)
      : undefined;
    return { ...r, coverImage, restImages, avatarImage };
  })
);
---

<section
  id="reviews"
  class="reviews-diagonal-bg py-12 sm:py-16 lg:py-24 border-t border-neutral-200"
  aria-label="Reviews"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Reviews</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">What Anchorage Is Saying.</h2>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <div class="flex items-center gap-2">
          <span class="text-amber-500 text-lg" aria-hidden="true">★★★★★</span>
          <span class="font-bold text-neutral-800">{averageRating}</span>
          <span class="text-neutral-500 uppercase font-semibold">Average</span>
        </div>
        <span class="text-neutral-300">|</span>
        <span class="text-neutral-600 font-semibold">{googleReviewCount} Google Reviews</span>
        <a
          href="https://www.google.com/search?q=deckmasters+anchorage+reviews"
          target="_blank"
          rel="noopener"
          class="text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider"
        >
          See All Google Reviews →
        </a>
      </div>
    </div>
    <div class="columns-1 md:columns-4 column-gap-4">
      {
        reviewsResolved.map((r) => {
          const initial = (r.author_name || '?').charAt(0).toUpperCase();
          const rating = Math.round(Number(r.rating) || 0);
          const hasProjectImages = !!r.coverImage;
          return (
            <div class="flex flex-col rounded-none border border-neutral-200 bg-surface-elevated p-5 shadow-sm break-inside-avoid mb-4">
              <div class="flex text-amber-500 text-sm mb-2" aria-label={`${rating} out of 5 stars`}>
                {[1, 2, 3, 4, 5].map((i) => (
                  <span class={i <= rating ? 'text-amber-500' : 'text-neutral-300'}>★</span>
                ))}
              </div>
              <p class="text-neutral-700 text-sm leading-relaxed mb-4 whitespace-pre-line">{r.review_text}</p>
              {hasProjectImages && r.coverImage ? (
                <div class="-mx-5 mb-4" aria-label="Project photos">
                  <Image
                    src={r.coverImage}
                    width={400}
                    height={225}
                    alt=""
                    class="w-full aspect-video object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                  {r.restImages.length > 0 ? (
                    <div class="mt-1 grid grid-cols-2 gap-0.5">
                      {r.restImages.map((img) => (
                        <Image
                          src={img}
                          width={200}
                          height={113}
                          alt=""
                          class="w-full aspect-video object-cover"
                          loading="lazy"
                          decoding="async"
                        />
                      ))}
                    </div>
                  ) : null}
                </div>
              ) : null}
              <footer class="flex items-center gap-3 pt-2 border-t border-neutral-100">
                {r.avatarImage ? (
                  <Image
                    src={r.avatarImage}
                    width={40}
                    height={40}
                    alt=""
                    class="h-10 w-10 shrink-0 rounded-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-neutral-200 text-sm font-semibold text-neutral-600"
                    aria-hidden="true"
                  >
                    {initial}
                  </span>
                )}
                <div>
                  <p class="font-semibold text-neutral-800 text-sm">{r.author_name}</p>
                  <p class="text-xs text-neutral-500">
                    {r.publish_date ? `Google · ${r.publish_date}` : 'Google'}
                  </p>
                </div>
              </footer>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
