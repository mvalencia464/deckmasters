---
/**
 * Shared “Internal admin” link list for /admin/publishing, /admin/site-structure, etc.
 * Pass `pathname` from `Astro.url.pathname` to highlight the current page.
 */
import { adminInternalNav } from '../data/siteStructureAdmin';

interface Props {
  pathname: string;
  /** Omit top border/padding when placed as the first block inside a wrapper (e.g. copywriting library). */
  flush?: boolean;
}

const { pathname, flush = false } = Astro.props;

function normalizePath(p: string): string {
  const t = p.replace(/\/$/, '');
  return t === '' ? '/' : t;
}

const here = normalizePath(pathname);

function isCurrent(href: string): boolean {
  return normalizePath(href) === here;
}
---

<nav class:list={[flush ? '' : 'border-t border-neutral-100 pt-4']} aria-label="Internal admin">
  <h3 class="font-display text-sm font-bold uppercase tracking-tight text-neutral-900">Internal admin</h3>
  <ul class="mt-3 space-y-3" role="list">
    {
      adminInternalNav.map((item) => {
        const current = isCurrent(item.href);
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm transition-colors',
                current
                  ? 'font-semibold text-neutral-900'
                  : 'font-medium text-accent-dark underline-offset-2 hover:underline',
              ]}
              aria-current={current ? 'page' : undefined}
            >
              {item.label}
              {current && <span class="font-normal text-neutral-500"> (this page)</span>}
            </a>
            <span class="mt-0.5 block font-mono text-[11px] text-neutral-400">{item.href}</span>
          </li>
        );
      })
    }
  </ul>
</nav>
