---
/**
 * “Project discovery” cards — obvious tap/click affordance (on-brand, no JS).
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

{
  projects.length > 0 && (
    <section class="mt-16 sm:mt-24 border-t border-neutral-200 pt-12 sm:pt-16">
      <div class="text-center mb-10 max-w-2xl mx-auto">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Project Discovery</p>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-neutral-900 tracking-tight">
          Explore more of our featured builds
        </h2>
        <p class="mt-3 text-sm text-neutral-600 leading-relaxed">
          Each project opens its own page — full photo sets, scope notes, and details you can share.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((p) => (
          <a
            href={`/projects/${p.id}`}
            class="group block rounded-none border-2 border-neutral-200 bg-surface hover:border-brand-orange hover:shadow-md transition-[border-color,box-shadow] duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-orange focus-visible:ring-offset-2"
          >
            <div class="relative aspect-video w-full overflow-hidden bg-neutral-100 border-b-2 border-neutral-200 group-hover:border-brand-orange transition-colors">
              <Image
                src={p.data.featuredImage}
                alt={p.data.h1}
                width={400}
                height={225}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              />
              <span class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/65 to-transparent pt-10 pb-2 px-3 sm:pt-12 sm:pb-3">
                <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-wider text-white drop-shadow-sm">
                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-orange text-white shadow-md shrink-0" aria-hidden="true">
                    <svg class="h-3.5 w-3.5 ml-px" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                  Open project
                </span>
              </span>
            </div>
            <div class="p-4 sm:p-5">
              <h3 class="font-display font-semibold text-neutral-900 group-hover:text-brand-orange transition-colors leading-snug">
                {p.data.h1}
              </h3>
              <p class="mt-2 text-xs text-neutral-600 line-clamp-2 leading-relaxed">{p.data.subhead}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-brand-orange border-b-2 border-brand-orange/40 group-hover:border-brand-orange pb-0.5 transition-colors">
                View full project
                <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}
