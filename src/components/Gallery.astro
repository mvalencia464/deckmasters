---
import { Image } from 'astro:assets';
// Placeholder gallery: 4–6 images. Client will provide fresh photos later.
const images = [
  { src: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=75', alt: 'Custom deck and outdoor living space' },
  { src: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600&q=75', alt: 'Deck with railing and mountain view' },
  { src: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=600&q=75', alt: 'Modern deck and exterior' },
  { src: 'https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde?w=600&q=75', alt: 'Composite deck and stairs' },
  { src: 'https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=600&q=75', alt: 'Deck repair and railing' },
  { src: 'https://images.unsplash.com/photo-1600585154526-990dced4db0d?w=600&q=75', alt: 'Outdoor structure and deck' },
];
---

<section class="py-12 sm:py-16 lg:py-24 bg-surface-muted border-t border-neutral-200" aria-label="Project gallery">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Portfolio</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">Our Work.</h2>
      <p class="mt-3 text-neutral-600 max-w-xl">
        Durable decks and outdoor spaces built for cold-climate living.
      </p>
    </div>
    <ul class="grid grid-cols-2 md:grid-cols-3 gap-4" role="list">
      {images.map((img) => (
        <li>
          <Image
            src={img.src}
            alt={img.alt}
            width={600}
            height={400}
            class="rounded-none w-full aspect-[3/2] object-cover border border-neutral-200 shadow-sm"
            loading="lazy"
            format="avif"
          />
        </li>
      ))}
    </ul>
  </div>
</section>
