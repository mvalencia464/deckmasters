---
// Placeholder quote CTA; form is in QuoteForm island (contact page + optional anchor on home).
---

<section id="quote" class="py-20 lg:py-28 bg-surface">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold text-neutral-800">Get a Free Quote</h2>
      <p class="mt-4 text-neutral-600">
        Tell us about your project. We'll respond with a clear estimate and next steps.
      </p>
      <a
        href="/contact#quote"
        class="mt-8 inline-flex items-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white transition-colors duration-200 hover:bg-accent-dark focus-ring"
      >
        Request Free Quote
      </a>
    </div>
  </div>
</section>
