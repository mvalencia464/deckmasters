---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const site = (await import('../data/site.json')).default;
const fullTitle = `${title} | ${site.businessName}`;
const metaDescription = description ?? `${site.tagline} Custom decks, repairs & outdoor living in ${site.primaryCity}, AK. Free estimates.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      />
    </noscript>
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 w-full bg-white border-b border-neutral-200/80">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center transition-opacity duration-200 hover:opacity-90 focus-ring rounded-sm">
          <span class="font-display text-2xl tracking-tighter font-bold text-brand-wood">{site.businessName.split(' ')[0]} <span class="text-brand-orange">{site.businessName.split(' ').slice(1).join(' ')}</span></span>
        </a>
        <div class="hidden md:flex items-center gap-8 font-medium text-xs uppercase tracking-[0.2em] text-neutral-600">
          <a href="/" class="hover:text-brand-orange transition-colors duration-200">Home</a>
          <a href="/services" class="hover:text-brand-orange transition-colors duration-200">Services</a>
          <a href="/#reviews" class="hover:text-brand-orange transition-colors duration-200">Reviews</a>
          <a href="/about" class="hover:text-brand-orange transition-colors duration-200">About</a>
          <a href="/contact" class="hover:text-brand-orange transition-colors duration-200">Contact</a>
        </div>
        <details class="md:hidden group relative">
          <summary class="list-none cursor-pointer text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest py-3 px-2 -mx-2 min-h-[44px] flex items-center">Menu</summary>
          <ul class="absolute top-full left-0 right-0 bg-white border-b border-neutral-200 px-4 py-3 flex flex-col gap-0 shadow-lg">
            <li><a href="/" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Home</a></li>
            <li><a href="/services" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Services</a></li>
            <li><a href="/#reviews" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Reviews</a></li>
            <li><a href="/about" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">About</a></li>
            <li><a href="/contact" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest">Contact</a></li>
          </ul>
        </details>
        <div class="flex items-center gap-4 sm:gap-6">
          <div class="hidden lg:flex flex-col items-end">
            <span class="text-[10px] uppercase text-neutral-400 font-bold">Call us</span>
            <a href={`tel:${site.primaryPhone.replace(/\D/g, '')}`} class="text-sm font-bold text-brand-dark hover:text-brand-orange transition-colors">{site.primaryPhone}</a>
          </div>
          <a
            href="/#quote"
            class="shrink-0 bg-brand-orange hover:bg-orange-800 text-white px-5 py-3 font-bold text-sm uppercase tracking-wider transition-all shadow-md focus-ring rounded-none"
          >
            Get Quote →
          </a>
        </div>
      </nav>
    </header>
    <main class="pb-20 md:pb-0">
      <slot />
    </main>
    <a
      href={`tel:${site.primaryPhone.replace(/\D/g, '')}`}
      class="fixed left-0 right-0 z-40 md:hidden flex items-center justify-center gap-2 bg-brand-orange text-white font-bold text-sm py-3 rounded-none shadow-lg hover:bg-orange-800 active:scale-[0.98] transition-all focus-ring min-h-[52px] bottom-0 [padding-bottom:max(0.75rem,env(safe-area-inset-bottom))] [padding-left:max(1rem,env(safe-area-inset-left))] [padding-right:max(1rem,env(safe-area-inset-right))]"
      aria-label={`Call ${site.primaryPhone}`}
    >
      <svg class="w-5 h-5 shrink-0 text-white" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span>{site.primaryPhone}</span>
    </a>
    <footer class="bg-neutral-100 border-t border-neutral-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
          <div>
            <p class="font-semibold text-neutral-800">{site.businessName}</p>
            {site.tagline && <p class="mt-2 text-sm text-neutral-600">{site.tagline}</p>}
          </div>
          <div>
            <p class="font-medium text-neutral-800">Hours</p>
            <p class="mt-2 text-sm text-neutral-600">{site.operatingHours || 'Contact for availability'}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Address</p>
            <p class="mt-2 text-sm text-neutral-600">{site.address}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Connect</p>
            <div class="mt-3 flex flex-wrap gap-4" aria-label="Social media">
              {site.socials.instagram && (
                <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              )}
              {site.socials.facebook && (
                <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {site.socials.linkedin && (
                <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
              {site.socials.yelp && (
                <a href={site.socials.yelp} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Yelp">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 0 0-.182-1.496 1.03 1.03 0 0 0-1.473.184L11.99 12.33c-.767 1.065-2.43.814-2.43-.485V4.575a1.03 1.03 0 0 0-.672-.954 1.03 1.03 0 0 0-1.392.675l-1.155 4.33c-.255.957-.558 1.888-.91 2.796-.35.903-.763 1.776-1.234 2.614a1.03 1.03 0 0 0 .566 1.455l4.994 1.433c.96.276 1.74-.8 1.176-1.63L5.5 12.33a1.072 1.072 0 0 0 .182-1.496 1.03 1.03 0 0 0-1.473-.184L.85 15.598c-.767 1.065-.764 2.54.006 3.602.77 1.06 2.206 1.595 3.415 1.072l4.995-1.433c.96-.276 1.74.8 1.176 1.63l-2.905 4.308a1.072 1.072 0 0 0 .182 1.496 1.03 1.03 0 0 0 1.473-.184l2.905-4.308c.767-1.065 2.43-.814 2.43.485v6.775a1.03 1.03 0 0 0 .672.954 1.03 1.03 0 0 0 1.392-.675l1.155-4.33c.255-.957.558-1.888.91-2.796.35-.903.763-1.776 1.234-2.614a1.03 1.03 0 0 0-.566-1.455l-4.994-1.433c-.96-.276-1.74.8-1.176 1.63l2.905 4.308a1.072 1.072 0 0 1-.182 1.496 1.03 1.03 0 0 1-1.473-.184l-2.905-4.308c-.767-1.065-.764-2.54-.006-3.602.77-1.06 2.206-1.595 3.415-1.072l4.995 1.433c.96.276 1.74-.8 1.176-1.63l2.905-4.308a1.072 1.072 0 0 0-.182-1.496 1.03 1.03 0 0 0-1.473.184L12.01 11.67c-.767-1.065-2.43-.814-2.43.485v6.775a1.03 1.03 0 0 0 .672.954 1.03 1.03 0 0 0 1.392-.675l1.155-4.33c.255-.957.558-1.888.91-2.796.35-.903.763-1.776 1.234-2.614a1.03 1.03 0 0 0-.566-1.455z"/></svg>
                </a>
              )}
              {site.socials.houzz && (
                <a href={site.socials.houzz} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Houzz">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l2.363 2.363a1.053 1.053 0 0 1-.006 1.489l-2.35 2.35h4.667a10.017 10.017 0 0 0 7.343 3.176 10.03 10.03 0 0 0 7.344-3.176h4.666l-2.35-2.35a1.053 1.053 0 0 1-.006-1.49l2.363-2.362h-4.361a10.016 10.016 0 0 0-7.645-2.353zM12 8.255c-1.067 0-2.077.208-3 .585l3 5.196 3-5.196a5.475 5.475 0 0 0-3-.585zm0 8.49l-3-5.196a5.468 5.468 0 0 0 6 0zm10.006-4.295c-2.67 0-5.338.784-7.645 2.353H12l2.363 2.363a1.053 1.053 0 0 1-.006 1.489l-2.35 2.35h4.667a10.017 10.017 0 0 0 7.343 3.176 10.03 10.03 0 0 0 7.344-3.176H24l-2.35-2.35a1.053 1.053 0 0 1-.006-1.49l2.363-2.362z"/></svg>
                </a>
              )}
              {site.socials.bbb && (
                <a href={site.socials.bbb} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Better Business Bureau">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h2v-6h-2v6zm0-8h2V7h-2v2z"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-neutral-200 flex flex-wrap items-center justify-between gap-4">
          <p class="text-sm text-neutral-500">© {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
          <div class="flex flex-wrap gap-6 text-sm text-neutral-500">
            <span>Free estimates</span>
            <span>Climate-durable builds</span>
            <span>Satisfaction guarantee</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
