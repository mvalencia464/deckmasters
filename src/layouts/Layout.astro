---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const site = (await import('../data/site.json')).default;
const fullTitle = `${title} | ${site.businessName}`;
const metaDescription = description ?? `${site.tagline} Custom decks, repairs & outdoor living in ${site.primaryCity}, AK. Free estimates.`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      />
    </noscript>
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 w-full bg-white border-b border-neutral-200/80">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center transition-opacity duration-200 hover:opacity-90 focus-ring rounded-sm">
          <span class="font-display text-2xl tracking-tighter font-bold text-brand-wood">{site.businessName.split(' ')[0]} <span class="text-brand-orange">{site.businessName.split(' ').slice(1).join(' ')}</span></span>
        </a>
        <div class="hidden md:flex items-center gap-8 font-medium text-xs uppercase tracking-[0.2em] text-neutral-600">
          <a href="/" class="hover:text-brand-orange transition-colors duration-200">Home</a>
          <a href="/services" class="hover:text-brand-orange transition-colors duration-200">Services</a>
          <a href="/#reviews" class="hover:text-brand-orange transition-colors duration-200">Reviews</a>
          <a href="/about" class="hover:text-brand-orange transition-colors duration-200">About</a>
          <a href="/contact" class="hover:text-brand-orange transition-colors duration-200">Contact</a>
        </div>
        <details class="md:hidden group relative">
          <summary class="list-none cursor-pointer text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest py-3 px-2 -mx-2 min-h-[44px] flex items-center">Menu</summary>
          <ul class="absolute top-full left-0 right-0 bg-white border-b border-neutral-200 px-4 py-3 flex flex-col gap-0 shadow-lg">
            <li><a href="/" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Home</a></li>
            <li><a href="/services" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Services</a></li>
            <li><a href="/#reviews" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">Reviews</a></li>
            <li><a href="/about" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest border-b border-neutral-100">About</a></li>
            <li><a href="/contact" class="block py-3 text-neutral-600 hover:text-brand-orange text-xs uppercase tracking-widest">Contact</a></li>
          </ul>
        </details>
        <div class="flex items-center gap-4 sm:gap-6">
          <div class="hidden lg:flex flex-col items-end">
            <span class="text-[10px] uppercase text-neutral-400 font-bold">Call us</span>
            <a href={`tel:${site.primaryPhone.replace(/\D/g, '')}`} class="text-sm font-bold text-brand-dark hover:text-brand-orange transition-colors">{site.primaryPhone}</a>
          </div>
          <a
            href="/#quote"
            class="shrink-0 bg-brand-orange hover:bg-orange-800 text-white px-5 py-3 font-bold text-sm uppercase tracking-wider transition-all shadow-md focus-ring rounded-none"
          >
            Get Quote →
          </a>
        </div>
      </nav>
    </header>
    <main class="pb-20 md:pb-0">
      <slot />
    </main>
    <a
      href={`tel:${site.primaryPhone.replace(/\D/g, '')}`}
      class="fixed left-0 right-0 z-40 md:hidden flex items-center justify-center gap-2 bg-brand-orange text-white font-bold text-sm py-3 rounded-none shadow-lg hover:bg-orange-800 active:scale-[0.98] transition-all focus-ring min-h-[52px] bottom-0 [padding-bottom:max(0.75rem,env(safe-area-inset-bottom))] [padding-left:max(1rem,env(safe-area-inset-left))] [padding-right:max(1rem,env(safe-area-inset-right))]"
      aria-label={`Call ${site.primaryPhone}`}
    >
      <svg class="w-5 h-5 shrink-0 text-white" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span>{site.primaryPhone}</span>
    </a>
    <footer class="bg-neutral-100 border-t border-neutral-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
          <div>
            <p class="font-semibold text-neutral-800">{site.businessName}</p>
            <p class="mt-2 text-sm text-neutral-600">{site.tagline}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Hours</p>
            <p class="mt-2 text-sm text-neutral-600">{site.operatingHours}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Address</p>
            <p class="mt-2 text-sm text-neutral-600">{site.address}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Connect</p>
            <div class="mt-2 flex gap-4">
              {site.socials.facebook && (
                <a href={site.socials.facebook} class="text-neutral-500 hover:text-accent transition-colors duration-200" aria-label="Facebook">Facebook</a>
              )}
              {site.socials.instagram && (
                <a href={site.socials.instagram} class="text-neutral-500 hover:text-accent transition-colors duration-200" aria-label="Instagram">Instagram</a>
              )}
              {site.socials.bbb && (
                <a href={site.socials.bbb} class="text-neutral-500 hover:text-accent transition-colors duration-200" aria-label="BBB">BBB</a>
              )}
            </div>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-neutral-200 flex flex-wrap items-center justify-between gap-4">
          <p class="text-sm text-neutral-500">© {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
          <div class="flex flex-wrap gap-6 text-sm text-neutral-500">
            <span>Free estimates</span>
            <span>Climate-durable builds</span>
            <span>Satisfaction guarantee</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
