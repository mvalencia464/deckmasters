# DataForSEO — required for `npm run build` (runs scripts/sync-reviews.js first)
# https://app.dataforseo.com/api-access
# Set the same vars in Cloudflare Pages → Settings → Environment variables (build).
DATAFORSEO_LOGIN=your_login_email
DATAFORSEO_PASSWORD=your_api_password

# Google Maps JavaScript API (Places Autocomplete on quote form).
# Create a key with Maps JavaScript API + Places API enabled; restrict by HTTP referrer
# (production domain, www, localhost, *.pages.dev previews). Use PUBLIC_ so it is available at build time.
#
# Cloudflare Pages: add the same names under Settings → Environment variables (do not commit values).
PUBLIC_GOOGLE_MAPS_API_KEY=

# HighLevel — used by Pages Function `functions/api/submit-quote.js`.
# Set on Cloudflare Pages → Settings → Environment variables (Production + Preview as needed).
# Token + location ID are both required at runtime; they are NOT injected by R2 or by wrangler.toml alone.
# HIGHLEVEL_TOKEN: use "Encrypt" (secret). HIGHLEVEL_LOCATION_ID: plain text (GHL location / sub-account UUID).
HIGHLEVEL_TOKEN=
HIGHLEVEL_LOCATION_ID=
HIGHLEVEL_CUSTOM_FIELD_PROJECT_DESCRIPTION=
HIGHLEVEL_CUSTOM_FIELD_QUOTE_IMAGE=

# Optional: when the quote form has a street line but no city/state/ZIP (typed address without
# Places, or incomplete test data), fill GHL/JobTread with your primary service area. All three
# must be set or none are applied.
QUOTE_FALLBACK_CITY=
QUOTE_FALLBACK_STATE=
QUOTE_FALLBACK_POSTAL_CODE=

# GitHub Actions only: repository secret CLOUDFLARE_PAGES_DEPLOY_HOOK_URL (scheduled daily deploy).
# Create the hook in Cloudflare Pages → Settings → Deploy hooks.

# Cloudflare R2 (S3-compatible API) — for scripts/media-upload-r2.mjs
# Dashboard → R2 → bucket → Settings → S3 API. Account ID is in the R2 overview URL / sidebar.
# Create an "API token" with Object Read & Write on this bucket (or use account API token with R2 permissions).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public origin for objects (no trailing path). Required for `astro build`: project images and r2-loader resolve keys with this base.
# Must match a hostname in astro.config.mjs → image.domains when using <Image />.
R2_PUBLIC_BASE_URL=https://media.example.com

# Optional multi-site prefix for object keys in the R2 bucket (e.g. deckmasters).
# Flat keys in content look like <client>/<file>; public URLs are <base>/<slug>/<client>/<file>.
R2_SITE_SLUG=

# Temporary: if true, flat keys in Markdown resolve to …/projects/<client>/<file> (legacy URL shape).
# Use only while objects still live only under bucket-root projects/… . Set false after backfill/upload
# to <R2_SITE_SLUG>/<client>/… — see docs/media-management.md
R2_LEGACY_PREPEND_PROJECTS=false

# ---------------------------------------------------------------------------
# Tracking — Cloudflare Zaraz (no script tags needed; Zaraz injects at edge)
# These values live in the Zaraz dashboard, NOT in this .env.
# They are documented here as a reference so IDs are never lost.
# See docs/zaraz/zaraz-config.json for the importable Zaraz config.
# ---------------------------------------------------------------------------

# Google Analytics 4
# GA4_STREAM_ID=5964125496
# GA4_MEASUREMENT_ID=G-CLD2MQ2F7L

# Google Ads
# GOOGLE_ADS_CONVERSION_ID=AW-879524969    ← confirmed correct (Form Fill tag snippet shows this ID)
# GOOGLE_ADS_OTHER_ID=AW-8713494041        ← separate account, not used in Zaraz
#
# Conversion labels (set in Zaraz → Google Ads tool → each conversion action):
#   Phone Calls from Website  → fires on phone_click  (tel: link clicks)
#   form_fill_quote           → fires on form_submit   (quote form)
#   form_fill_hiring          → fires on form_submit   (hiring form, if added)
#
# NOT managed by Zaraz (fires automatically through Google's own system):
#   Call For Ads              → Calls from ads (Google auto-inserts forwarding number)
#   Lead form - Submit        → Google-hosted lead form (no website tag needed)
#
# Enhanced Conversions: must be enabled in Google Ads → Goals → Conversions → Settings
#   → "Enhanced conversions for leads" → ON → "Manually set up enhanced conversions"
#   Zaraz hashes the email client-side and passes it via {{ client.hashed_email }}

# Meta Pixel
# META_PIXEL_ID=492022321570146

# Sale confirmation page token (guards /sale-confirmed against unauthorized tracking fires).
# Generate any random secret and set it in Cloudflare Pages → Settings → Environment variables.
SALE_CONFIRM_TOKEN=

# CRM sale webhook token (guards POST /api/sale-webhook).
# Generate any random secret and set it in Cloudflare Pages → Settings → Environment variables.
SALE_WEBHOOK_TOKEN=
