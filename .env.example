# DataForSEO — required for `npm run build` (runs scripts/sync-reviews.js first)
# https://app.dataforseo.com/api-access
# Set the same vars in Cloudflare Pages → Settings → Environment variables (build).
DATAFORSEO_LOGIN=your_login_email
DATAFORSEO_PASSWORD=your_api_password

# GitHub Actions only: repository secret CLOUDFLARE_PAGES_DEPLOY_HOOK_URL (scheduled daily deploy).
# Create the hook in Cloudflare Pages → your project → Settings → Deploy hooks.
