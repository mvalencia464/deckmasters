# DataForSEO API — required for `npm run build` (runs scripts/sync-reviews.js first)
# https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_login_email
DATAFORSEO_PASSWORD=your_api_password

# Cloudflare Pages: set the same vars under Settings → Environment variables (build).

# POST /api/mgr-webhook — shared secret for triggering a production redeploy (GHL, cron, etc.)
MGR_WEBHOOK_SECRET=

# Cloudflare Pages deploy hook URL (POST). Do not commit the real URL.
CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=
