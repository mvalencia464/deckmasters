# DataForSEO API (for scripts/sync-reviews.js)
# Copy to .env and fill in your credentials from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_login_email
DATAFORSEO_PASSWORD=your_api_password

# Optional: override task id if you use a different Google Reviews task
# DATAFORSEO_TASK_ID=04011058-0696-0199-0000-2196151a15cb

# More Good Reviews — https://moregoodreviews.com/settings/api
# Used at build (fetch-mgr-reviews.js → src/data/reviews.json). Set in Cloudflare Pages build env too.
MGR_API_KEY=

# Webhook auth for POST /api/mgr-webhook (header X-Webhook-Secret). Production + preview in Pages.
MGR_WEBHOOK_SECRET=

# Cloudflare Pages deploy hook URL (POST). Do not commit the real URL.
CLOUDFLARE_PAGES_DEPLOY_HOOK_URL=
