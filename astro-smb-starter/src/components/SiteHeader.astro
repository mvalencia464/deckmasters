---
import iconSvg from '../assets/icon.svg';

const site = (await import('../data/site.json')).default;
const iconSrc = typeof iconSvg === 'string' ? iconSvg : iconSvg.src;
const telHref = `tel:${site.primaryPhone.replace(/\D/g, '')}`;

const nameParts = site.businessName.trim().split(/\s+/);
const logoFirst = nameParts[0] ?? '';
const logoRest = nameParts.slice(1).join(' ');
---

<header class="sticky top-0 z-50 w-full border-b border-neutral-200/80 bg-white">
  <nav class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Main">
    <input
      type="checkbox"
      id="menu-toggle"
      class="peer sr-only"
      aria-label="Open or close main menu"
      aria-expanded="false"
    />

    <!-- Mobile full-screen menu -->
    <div
      class="pointer-events-none fixed inset-0 z-40 translate-x-full transform bg-white transition-transform duration-300 ease-out peer-checked:pointer-events-auto peer-checked:translate-x-0 md:hidden"
      aria-hidden="true"
    >
      <div class="flex min-h-full flex-col px-6 pb-8 pt-24">
        <label
          for="menu-toggle"
          class="focus-ring absolute top-6 right-4 -m-2 cursor-pointer rounded-sm p-2 text-neutral-600 hover:text-brand-orange"
          aria-label="Close menu"
        >
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg
          >
        </label>
        <ul class="flex flex-col gap-0 text-center" role="list">
          {
            site.nav.map((item: { label: string; href: string }) => (
              <li>
                <a
                  href={item.href}
                  class="block border-b border-neutral-100 py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <a
          href={telHref}
          class="focus-ring mx-auto mt-8 w-full max-w-xs border-2 border-white/25 bg-brand-orange px-6 py-4 text-center text-sm font-bold tracking-wider text-white uppercase shadow-lg transition-colors hover:bg-orange-800"
        >
          Call {site.primaryPhone}
        </a>
      </div>
    </div>

    <div class="flex h-20 items-center justify-between gap-4">
      <div class="flex min-w-0 flex-1 items-center gap-3 md:flex-none">
        <label
          for="menu-toggle"
          class="focus-ring flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center rounded-sm text-neutral-600 hover:text-brand-orange md:hidden"
          aria-label="Open menu"
        >
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg
          >
        </label>

        <a href="/" class="focus-ring flex min-w-0 items-center gap-1.5">
          <img src={iconSrc} alt="" width="36" height="32" class="h-8 w-auto shrink-0" fetchpriority="high" />
          <span
            class="font-display overflow-visible pr-px text-2xl font-bold tracking-tight text-neutral-800 uppercase md:text-3xl"
          >
            {logoFirst}
            {logoRest ? <span class="brand-text-gradient">{logoRest}</span> : null}
          </span>
        </a>
      </div>

      <div class="hidden items-center gap-8 text-xs font-medium tracking-[0.2em] text-neutral-600 uppercase md:flex">
        {
          site.nav.map((item: { label: string; href: string }) => (
            <a href={item.href} class="transition-colors duration-200 hover:text-brand-orange">
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex shrink-0 items-center gap-3">
        <div class="hidden flex-col items-end md:flex">
          <span class="text-[10px] font-bold text-neutral-600 uppercase">Call us</span>
          <a href={telHref} class="text-sm font-bold text-brand-dark transition-colors hover:text-brand-orange">
            {site.primaryPhone}
          </a>
        </div>
        <a
          href={telHref}
          class="phone-cta-soft-pulse flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full bg-brand-orange text-white transition-colors hover:bg-orange-800 focus-ring md:hidden"
          aria-label={`Call ${site.primaryPhone}`}
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </nav>
</header>
