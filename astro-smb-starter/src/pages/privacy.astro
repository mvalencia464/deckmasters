---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy" verbatimTitle>
  <section class="bg-surface py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl font-bold tracking-tight text-neutral-800 uppercase sm:text-4xl">
        Privacy Policy
      </h1>
      <p class="mt-6 text-sm text-neutral-600 leading-relaxed">
        Replace this placeholder with your real privacy policy. Consider having it reviewed for your jurisdiction and
        analytics or form tools you use.
      </p>
    </div>
  </section>
</Layout>
