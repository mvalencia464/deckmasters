---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <section class="bg-surface py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl font-bold tracking-tight text-neutral-800 uppercase sm:text-4xl">About</h1>
      <p class="mt-6 text-neutral-600 leading-relaxed">
        Add your story, credentials, and service area. This page is a placeholder.
      </p>
    </div>
  </section>
</Layout>
