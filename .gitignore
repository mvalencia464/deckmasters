# Dependencies
node_modules/

# Build
dist/
.astro/

# Env — never commit real secrets. `git status` should never show .env or .dev.vars.
.env
.env.*
!.env.example
# Wrangler: local overrides for `wrangler dev` / deploy (same KEY=value idea as .env)
.dev.vars

# IDE / OS
.DS_Store
*.log
.cache

# Wrangler
.wrangler/

# Optional local AVIF output before upload (not required; astro build optimizes R2 remotes)
media/dist/
# Large local upload staging (sync to R2 with npm run media:upload; do not commit binaries)
media/raw/

# Large media (tracked via external storage - served from R2)
public/Keller-video.mov
public/keller.mov
public/keller.mp4
# GitHub rejects blobs > 100 MB — transcode or host on R2 before referencing in content
src/assets/projects/matt-blakeslee/IMG_6982.mov
