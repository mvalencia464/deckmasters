{
  "comment": "Zaraz configuration for deckmastersak.com",
  "comment2": "Import via: Cloudflare Dashboard > Zaraz > Tools Configuration > Import/Export",
  "comment3": "variables is {} on purpose: Worker variables need value.workerTag + value.escapedWorkerName from a deployed Worker. After import, add hashed_email in Zaraz > Variables (see SETUP-GUIDE Step 3 + zaraz-email-hasher-worker.js).",
  "tools": {
    "ga4": {
      "type": "component",
      "component": "google-analytics-4",
      "name": "Google Analytics 4",
      "enabled": true,
      "blockingTriggers": [],
      "permissions": [],
      "defaultFields": {},
      "settings": {
        "measurementId": "G-CLD2MQ2F7L"
      },
      "actions": {
        "pageview": {
          "actionType": "pageview",
          "blockingTriggers": [],
          "firingTriggers": ["Pageview"],
          "data": {}
        },
        "form_lead": {
          "actionType": "event",
          "blockingTriggers": [],
          "firingTriggers": ["FormSubmit"],
          "data": {
            "eventName": "generate_lead",
            "fields": {
              "method": "website_form"
            }
          }
        },
        "phone_call": {
          "actionType": "event",
          "blockingTriggers": [],
          "firingTriggers": ["PhoneCallClick"],
          "data": {
            "eventName": "generate_lead",
            "fields": {
              "method": "phone_call"
            }
          }
        },
        "sale": {
          "actionType": "event",
          "blockingTriggers": [],
          "firingTriggers": ["SaleComplete"],
          "data": {
            "eventName": "purchase",
            "fields": {
              "currency": "USD",
              "value": "{{ client.sale_value }}"
            }
          }
        }
      }
    },
    "google_ads": {
      "type": "component",
      "component": "google-ads",
      "name": "Google Ads",
      "enabled": true,
      "blockingTriggers": [],
      "permissions": [],
      "defaultFields": {},
      "settings": {
        "conversionId": "AW-879524969"
      },
      "actions": {
        "call_conversion": {
          "actionType": "conversion",
          "blockingTriggers": [],
          "firingTriggers": ["PhoneCallClick"],
          "data": {
            "conversionLabel": "Phone Calls from Website",
            "enhancedConversions": true,
            "userEmail": "{{ client.hashed_email }}"
          }
        },
        "lead_conversion": {
          "actionType": "conversion",
          "blockingTriggers": [],
          "firingTriggers": ["FormSubmit"],
          "data": {
            "conversionLabel": "JZz9CKWE3KUBEOn4saMD",
            "enhancedConversions": true,
            "userEmail": "{{ client.hashed_email }}"
          }
        },
        "sale_conversion": {
          "actionType": "conversion",
          "blockingTriggers": [],
          "firingTriggers": ["SaleComplete"],
          "data": {
            "conversionLabel": "JZz9CKWE3KUBEOn4saMD",
            "enhancedConversions": true,
            "userEmail": "{{ client.hashed_email }}",
            "conversionValue": "{{ client.sale_value }}"
          }
        }
      }
    },
    "meta_pixel": {
      "type": "component",
      "component": "facebook-pixel",
      "name": "Meta Pixel",
      "enabled": true,
      "blockingTriggers": [],
      "permissions": [],
      "defaultFields": {},
      "settings": {
        "pixelId": "492022321570146"
      },
      "actions": {
        "pageview": {
          "actionType": "PageView",
          "blockingTriggers": [],
          "firingTriggers": ["Pageview"],
          "data": {}
        },
        "lead": {
          "actionType": "Lead",
          "blockingTriggers": [],
          "firingTriggers": ["FormSubmit"],
          "data": {
            "userEmail": "{{ client.hashed_email }}"
          }
        },
        "purchase": {
          "actionType": "Purchase",
          "blockingTriggers": [],
          "firingTriggers": ["SaleComplete"],
          "data": {
            "value": "{{ client.sale_value }}",
            "currency": "USD"
          }
        }
      }
    }
  },
  "triggers": {
    "Pageview": {
      "name": "Pageview",
      "excludeRules": [],
      "loadRules": [
        {
          "id": "rule-pageview-event-name",
          "match": "Event Name",
          "op": "EQUALS",
          "value": "Pageview"
        }
      ]
    },
    "FormSubmit": {
      "name": "Form Submit",
      "excludeRules": [],
      "loadRules": [
        {
          "id": "rule-form-submit-event-name",
          "match": "Event Name",
          "op": "EQUALS",
          "value": "form_submit"
        }
      ]
    },
    "PhoneCallClick": {
      "name": "Phone Call Click",
      "excludeRules": [],
      "loadRules": [
        {
          "id": "rule-phone-click-event-name",
          "match": "Event Name",
          "op": "EQUALS",
          "value": "phone_click"
        }
      ]
    },
    "SaleComplete": {
      "name": "Sale Complete",
      "excludeRules": [],
      "loadRules": [
        {
          "id": "rule-sale-complete-event-name",
          "match": "Event Name",
          "op": "EQUALS",
          "value": "sale_complete"
        }
      ]
    }
  },
  "variables": {}
}
