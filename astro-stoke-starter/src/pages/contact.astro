---
import Layout from '../layouts/Layout.astro';

const site = (await import('../data/site.json')).default;
const telHref = `tel:${site.primaryPhone.replace(/\D/g, '')}`;
const mailHref = `mailto:${site.primaryEmail}`;
---

<Layout title="Contact">
  <section class="bg-surface py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="font-display text-3xl font-bold tracking-tight text-neutral-800 uppercase sm:text-4xl">Contact</h1>
      <p class="mt-6 text-neutral-600 leading-relaxed">
        Swap this section for a form (Netlify, Formspark, your API) or keep it simple with click-to-call and email.
      </p>
      <ul class="mt-10 space-y-4 text-neutral-800">
        <li>
          <span class="text-sm font-semibold text-neutral-500 uppercase">Phone</span>
          <br />
          <a href={telHref} class="text-lg font-semibold text-brand-orange hover:underline focus-ring rounded-sm">
            {site.primaryPhone}
          </a>
        </li>
        <li>
          <span class="text-sm font-semibold text-neutral-500 uppercase">Email</span>
          <br />
          <a href={mailHref} class="text-lg font-semibold text-brand-orange hover:underline focus-ring rounded-sm">
            {site.primaryEmail}
          </a>
        </li>
      </ul>
    </div>
  </section>
</Layout>
