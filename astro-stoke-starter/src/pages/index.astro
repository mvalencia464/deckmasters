---
import Layout from '../layouts/Layout.astro';

const site = (await import('../data/site.json')).default;
---

<Layout title="Home" description={`${site.tagline} ${site.primaryCity}.`}>
  <section class="border-b border-neutral-200 bg-surface py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="mb-2 text-xs font-bold tracking-[0.2em] text-brand-orange uppercase">Welcome</p>
      <h1
        class="font-display max-w-4xl text-3xl leading-[1.08] font-bold tracking-tight text-neutral-800 uppercase sm:text-4xl md:text-5xl"
      >
        Your headline goes here.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-neutral-600 leading-relaxed">
        Replace this block in <code class="rounded bg-neutral-200/80 px-1.5 py-0.5 text-sm">src/pages/index.astro</code> and
        update <code class="rounded bg-neutral-200/80 px-1.5 py-0.5 text-sm">src/data/site.json</code> with your business
        details.
      </p>
      <p class="mt-8">
        <a
          href="/contact"
          class="focus-ring inline-flex bg-brand-orange px-6 py-3 text-sm font-bold tracking-wider text-white uppercase transition-colors hover:bg-orange-800"
        >
          Contact us
        </a>
      </p>
    </div>
  </section>
</Layout>
