---
import iconSvg from '../assets/icon.svg';

const site = (await import('../data/site.json')).default;
const iconSrc = typeof iconSvg === 'string' ? iconSvg : iconSvg.src;
const telHref = `tel:${site.primaryPhone.replace(/\D/g, '')}`;
const year = new Date().getFullYear();

const nameParts = site.businessName.trim().split(/\s+/);
const logoFirst = nameParts[0] ?? '';
const logoRest = nameParts.slice(1).join(' ');
---

<footer
  class="relative z-10 border-t border-neutral-200 bg-surface pb-[max(1.25rem,env(safe-area-inset-bottom))] text-neutral-800 md:pb-0"
>
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <a href="/" class="focus-ring inline-flex items-center gap-2.5 rounded-sm transition-opacity hover:opacity-90">
          <img src={iconSrc} alt="" width="40" height="36" class="h-9 w-auto" />
          <span class="font-display text-2xl font-bold tracking-tight text-neutral-800 uppercase">
            {logoFirst}
            {logoRest ? <span class="brand-text-gradient">{logoRest}</span> : null}
          </span>
        </a>
        {site.tagline && <p class="mt-4 max-w-sm text-sm leading-relaxed text-neutral-600">{site.tagline}</p>}
        <div class="mt-6">
          <a
            href={telHref}
            class="focus-ring inline-flex items-center gap-2 bg-brand-orange px-4 py-2.5 text-sm font-semibold text-white shadow-md transition-colors hover:bg-orange-800"
          >
            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            {site.primaryPhone}
          </a>
        </div>
      </div>

      <nav aria-label="Footer">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-neutral-600" role="list">
          {
            site.footerNav.map((item: { label: string; href: string }) => (
              <li>
                <a href={item.href} class="hover:text-brand-orange">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <p class="mt-10 border-t border-neutral-200 pt-8 text-sm text-neutral-500">
      © {year}
      {site.businessName}. All rights reserved.
      {site.primaryCity ? ` · ${site.primaryCity}` : ''}
    </p>
  </div>
</footer>
